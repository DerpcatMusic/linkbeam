{
  "name": "linkbeam",
  "version": "0.1.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wrangler d1 migrations apply DB --local && bun scripts/dev.mjs",
    "dev:background": "wrangler d1 migrations apply DB --local && astro dev --background",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json --keep-vars",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "auth:hash": "bun scripts/hash-admin-password.mjs",
    "test": "vitest run",
    "smoke": "bash scripts/smoke-worker.sh"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14",
    "astro": "^7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260621.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.105.0"
  }
}
