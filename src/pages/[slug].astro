---
import LinkLayout from "@layouts/LinkLayout.astro";
import SmartlinkFanPage from "@components/SmartlinkFanPage.astro";
import { getPublishedLink, getLinkBySlug, incrementDailyMetric } from "@lib/db";
import { defer, getRuntimeEnv, publicBaseUrl, requireAdmin } from "@lib/runtime";
import { buildPixelScript, createEventId, getMetaCookiesToSet, hasPaidAttribution, metaPixelMethod, paidEventId, queueMetaEvent, resolveTrackingCookies, sha256Hex, trackingAttribution, trackingQuerySuffix } from "@lib/tracking";
import { recordMetricEvent } from "@lib/metrics";
import { isBot } from "@lib/bots";
import { getMetaConversionValue, getMetaCurrency, getMetaPixelId } from "@lib/settings";
import { artworkPublicPath } from "@lib/artwork";
import { effectiveLinkMode, presaveDestinationLabel, resolveClickEventName, resolvePaidClickEventName } from "@lib/effective-mode";
import { spotifyAppUri, spotifyDestinationUrl } from "@lib/spotify-links";

const env = getRuntimeEnv(Astro);
const slug = Astro.params.slug ?? "";
const preview = Astro.url.searchParams.get("preview") === "1";
const embedded = Astro.url.searchParams.get("embed") === "1";

let link = null;
let isDraftPreview = false;

if (preview) {
  const blocked = await requireAdmin(Astro.request, env);
  if (!blocked) {
    const draftLink = await getLinkBySlug(env, slug, false);
    if (draftLink && draftLink.status !== "published") {
      link = draftLink;
      isDraftPreview = true;
    }
  }
}

if (!link) {
  link = await getPublishedLink(env, slug);
}

if (!link) return Astro.redirect("/404", 404);

const effectiveMode = effectiveLinkMode(link);
const clickEventName = resolveClickEventName(link);
const paidClickEventName = resolvePaidClickEventName(link);
const clickEventMethod = metaPixelMethod(clickEventName);
const paidClickEventMethod = metaPixelMethod(paidClickEventName);
const paidAttribution = hasPaidAttribution(trackingAttribution(Astro.request));
const pageViewEventId = createEventId("view", link, "pageview");
let hashedExternalId: string | undefined;
const pixelId = await getMetaPixelId(env);
const trackTracking = !isDraftPreview && !isBot(Astro.request);
const clientHintHeaders = [
  "Sec-CH-UA",
  "Sec-CH-UA-Mobile",
  "Sec-CH-UA-Platform",
  "Sec-CH-UA-Platform-Version",
  "Sec-CH-UA-Model",
  "Sec-CH-UA-Full-Version-List"
].join(", ");

Astro.response.headers.set("Accept-CH", clientHintHeaders);
Astro.response.headers.set("Permissions-Policy", "ch-ua=*, ch-ua-mobile=*, ch-ua-platform=*, ch-ua-platform-version=*, ch-ua-model=*, ch-ua-full-version-list=*");

if (trackTracking) {
  const cookiesToSet = getMetaCookiesToSet(Astro.request);
  for (const cookie of cookiesToSet) {
    Astro.cookies.set(cookie.name, cookie.value, {
      path: "/",
      maxAge: cookie.maxAge ?? 7776000,
      sameSite: "lax",
      secure: Astro.url.protocol === "https:",
      httpOnly: cookie.httpOnly ?? false
    });
  }
  const trackingCookies = resolveTrackingCookies(Astro.request, cookiesToSet);
  hashedExternalId = trackingCookies.externalId ? await sha256Hex(trackingCookies.externalId) : undefined;

  defer(Astro, queueMetaEvent(env, Astro.request, link, {
    kind: "view",
    eventName: "PageView",
    eventId: pageViewEventId,
    cookies: trackingCookies
  }));
  defer(Astro, incrementDailyMetric(env, link.id, "views"));
  defer(Astro, recordMetricEvent(env, {
    linkId: link.id,
    kind: "view",
    request: Astro.request,
    cookies: trackingCookies
  }));
}

const baseUrl = publicBaseUrl(env, Astro.request).replace(/\/$/, "");
const artworkPath = artworkPublicPath(link.track);
const artwork = artworkPath.startsWith("http") ? artworkPath : `${baseUrl}${artworkPath}`;
const pageBackgroundStyle = link.page_background_style;
const buttonStyle = link.button_style;
const pageStyleOptions = link.page_style_options;
const isPresave = effectiveMode === "presave";
const pixelScript = trackTracking
  ? buildPixelScript({ pixelId, pageViewEventId, externalId: hashedExternalId })
  : null;
const pageTitle = `${link.track.title} — ${link.track.artist_name}`;
const description = isPresave
  ? `Pre-save ${link.track.title} by ${link.track.artist_name}.`
  : `Listen to ${link.track.title} by ${link.track.artist_name}.`;
const pageUrl = `${baseUrl}/${link.slug}${isDraftPreview ? "?preview=1" : ""}`;

const sortedDestinations = [...link.destinations].sort((a, b) => {
  if (a.platform === "spotify") return -1;
  if (b.platform === "spotify") return 1;
  return a.sort_order - b.sort_order;
});

const conversionValue = getMetaConversionValue(env);
const conversionCurrency = conversionValue === undefined ? undefined : getMetaCurrency(env);

const destinationRows = sortedDestinations.map((destination) => {
  const kind = isPresave ? "presave" : "click";
  const clickEventId = createEventId(kind, link, destination.platform);
  const paidClickEventIdValue = !isPresave && paidAttribution ? paidEventId(clickEventId) : "";
  const outboundSuffix = trackingQuerySuffix(Astro.url, { eid: clickEventId });
  const cta = presaveDestinationLabel(destination.label, effectiveMode);
  const fallbackUrl = spotifyDestinationUrl(link, destination);
  const appUri = !isPresave && destination.platform === "spotify" && link.spotify_open_behavior === "app_first"
    ? spotifyAppUri(destination.url, link.spotify_context_url)
    : null;
  const payload = {
    action: isPresave ? "pre_save" : "musicservice",
    servicename: destination.platform,
    content_name: link.track.title,
    content_category: "music",
    content_ids: [link.track.isrc ?? link.slug],
    content_type: "music",
    artist: link.track.artist_name,
    artists: link.track.artist_names,
    song_name: link.track.title,
    slug: link.slug,
    platform: destination.platform,
    link_type: isPresave ? "pre_release" : "post_release",
    cta,
    value: conversionValue,
    currency: conversionCurrency
  };

  return {
    destination,
    cta,
    eventId: clickEventId,
    eventName: clickEventName,
    eventMethod: clickEventMethod,
    eventPayload: JSON.stringify(payload),
    paidEventName: paidClickEventIdValue ? paidClickEventName : "",
    paidEventMethod: paidClickEventIdValue ? paidClickEventMethod : "",
    paidEventId: paidClickEventIdValue,
    href: `/out/${link.slug}/${destination.platform}${outboundSuffix}`,
    fallbackUrl,
    appUri
  };
});

const fanDestinations = destinationRows.map((row) => ({
  platform: row.destination.platform,
  cta: row.cta,
  href: row.href,
  trackAttrs: {
    "data-track-click": "",
    "data-event-id": row.eventId,
    "data-event-name": row.eventName,
    "data-event-method": row.eventMethod,
    "data-event-payload": row.eventPayload,
    "data-paid-event-name": row.paidEventName,
    "data-paid-event-method": row.paidEventMethod,
    "data-paid-event-id": row.paidEventId,
    "data-fallback-url": row.fallbackUrl,
    "data-app-uri": row.appUri ?? ""
  }
}));
---

<LinkLayout
  title={pageTitle}
  description={description}
  ogTitle={pageTitle}
  ogDescription={description}
  ogImage={artwork}
  ogUrl={pageUrl}
  twitterCard="summary_large_image"
  bodyClass={embedded ? "beamlink-link--embedded" : ""}
>
  <SmartlinkFanPage
    title={link.track.title}
    artistName={link.track.artist_name}
    isrc={link.track.isrc}
    artworkUrl={artwork}
    paletteJson={link.track.palette}
    releaseAt={link.track.release_at}
    effectiveMode={effectiveMode}
    pageBackgroundStyle={pageBackgroundStyle}
    buttonStyle={buttonStyle}
    pageStyleOptions={pageStyleOptions}
    destinations={fanDestinations}
    embedded={embedded}
    showDraftRibbon={isDraftPreview}
    interactive
  />

  {pixelScript && <script is:inline set:html={pixelScript}></script>}

  {trackTracking && pixelId && (
    <script is:inline>
      function collectClickDeviceParams() {
        const screenWidth = Math.round(window.screen?.width || 0);
        const screenHeight = Math.round(window.screen?.height || 0);
        const viewportWidth = Math.round(window.innerWidth || 0);
        const viewportHeight = Math.round(window.innerHeight || 0);
        return {
          sr: screenWidth && screenHeight ? `${screenWidth}x${screenHeight}` : "",
          vp: viewportWidth && viewportHeight ? `${viewportWidth}x${viewportHeight}` : "",
          dpr: window.devicePixelRatio ? String(window.devicePixelRatio) : "",
          tz: String(new Date().getTimezoneOffset()),
          lang: navigator.language || ""
        };
      }

      document.addEventListener("click", (event) => {
        const anchor = event.target?.closest?.("a[data-track-click]");
        if (!anchor) return;

        function withDeviceParams(rawHref, extra = {}) {
          const url = new URL(rawHref, window.location.origin);
          for (const [key, value] of Object.entries(collectClickDeviceParams())) {
            if (value) url.searchParams.set(key, value);
          }
          for (const [key, value] of Object.entries(extra)) {
            if (value) url.searchParams.set(key, value);
          }
          return url.toString();
        }

        try {
          anchor.href = withDeviceParams(anchor.href);
        } catch {
          // Keep the outbound click working if URL mutation fails.
        }

        function payloadFromAnchor() {
          try {
            return JSON.parse(anchor.dataset.eventPayload || "{}");
          } catch {
            return {};
          }
        }

        function firePixelEvent(eventName, eventId, method) {
          if (!eventName || !eventId || typeof window.fbq !== "function") return;
          fbq(method || "trackCustom", eventName, payloadFromAnchor(), { eventID: eventId });
        }

        firePixelEvent(anchor.dataset.eventName, anchor.dataset.eventId, anchor.dataset.eventMethod);
        firePixelEvent(anchor.dataset.paidEventName, anchor.dataset.paidEventId, anchor.dataset.paidEventMethod);

        const appUri = anchor.dataset.appUri;
        if (!appUri) return;

        event.preventDefault();
        let trackingUrl = anchor.href;
        try {
          trackingUrl = withDeviceParams(anchor.href, { track_only: "1" });
        } catch {
          trackingUrl = anchor.href.includes("?") ? `${anchor.href}&track_only=1` : `${anchor.href}?track_only=1`;
        }
        try {
          fetch(trackingUrl, { method: "GET", credentials: "include", keepalive: true });
        } catch {
          // Browser pixel already fired above; keep the tap moving.
        }

        let leftPage = false;
        const markLeft = () => { leftPage = true; };
        window.addEventListener("pagehide", markLeft, { once: true });
        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") markLeft();
        }, { once: true });

        window.location.href = appUri;
        window.setTimeout(() => {
          if (!leftPage && document.visibilityState !== "hidden") {
            window.location.href = anchor.dataset.fallbackUrl || anchor.href;
          }
        }, 1100);
      }, { capture: true });
    </script>
  )}

  {isPresave && (
    <script is:inline define:vars={{ linkId: link.id }}>
      const form = document.querySelector("#subscribeForm");
      const status = document.querySelector("#subscribeStatus");
      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (status) status.textContent = "Saving…";
        const email = document.querySelector("#email")?.value?.trim() ?? "";
        const website = document.querySelector("#website")?.value ?? "";
        const response = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ linkId, email, website })
        });
        const data = await response.json().catch(() => ({}));
        if (response.ok && data.created && data.eventId && typeof window.fbq === "function") {
          fbq("track", "CompleteRegistration", {}, { eventID: data.eventId, em: email });
        }
        if (status) {
          status.textContent = response.ok
            ? "You're on the list."
            : data.error || "Could not subscribe.";
        }
      });
    </script>
  )}
</LinkLayout>
