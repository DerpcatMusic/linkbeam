---
import LinkLayout from "@layouts/LinkLayout.astro";
import PlatformIcon from "@components/PlatformIcon.astro";
import { getPublishedLink, getLinkBySlug, incrementDailyMetric } from "@lib/db";
import { defer, getRuntimeEnv, publicBaseUrl, requireAdmin } from "@lib/runtime";
import { buildPixelScript, createEventId, getMetaCookiesToSet, hasPaidAttribution, metaPixelMethod, paidEventId, queueMetaEvent, resolveTrackingCookies, sha256Hex, trackingAttribution, trackingQuerySuffix } from "@lib/tracking";
import { recordMetricEvent } from "@lib/metrics";
import { isBot } from "@lib/bots";
import { getMetaConversionValue, getMetaCurrency, getMetaPixelId } from "@lib/settings";
import { artworkPublicPath } from "@lib/artwork";
import { effectiveLinkMode, presaveDestinationLabel, resolveClickEventName, resolvePaidClickEventName } from "@lib/effective-mode";
import { formatShortDate } from "@lib/datetime";
import { parseTrackPalette, paletteStyleAttribute } from "@lib/palette";
import { spotifyAppUri, spotifyDestinationUrl } from "@lib/spotify-links";

const env = getRuntimeEnv(Astro);
const slug = Astro.params.slug ?? "";
const preview = Astro.url.searchParams.get("preview") === "1";
const embedded = Astro.url.searchParams.get("embed") === "1";

let link = null;
let isDraftPreview = false;

if (preview) {
  const blocked = await requireAdmin(Astro.request, env);
  if (!blocked) {
    const draftLink = await getLinkBySlug(env, slug, false);
    if (draftLink && draftLink.status !== "published") {
      link = draftLink;
      isDraftPreview = true;
    }
  }
}

if (!link) {
  link = await getPublishedLink(env, slug);
}

if (!link) return Astro.redirect("/404", 404);

const effectiveMode = effectiveLinkMode(link);
const clickEventName = resolveClickEventName(link);
const paidClickEventName = resolvePaidClickEventName(link);
const clickEventMethod = metaPixelMethod(clickEventName);
const paidClickEventMethod = metaPixelMethod(paidClickEventName);
const paidAttribution = hasPaidAttribution(trackingAttribution(Astro.request));
const pageViewEventId = createEventId("view", link, "pageview");
let hashedExternalId: string | undefined;
const pixelId = await getMetaPixelId(env);
const trackTracking = !isDraftPreview && !isBot(Astro.request);
const clientHintHeaders = [
  "Sec-CH-UA",
  "Sec-CH-UA-Mobile",
  "Sec-CH-UA-Platform",
  "Sec-CH-UA-Platform-Version",
  "Sec-CH-UA-Model",
  "Sec-CH-UA-Full-Version-List"
].join(", ");

Astro.response.headers.set("Accept-CH", clientHintHeaders);
Astro.response.headers.set("Permissions-Policy", "ch-ua=*, ch-ua-mobile=*, ch-ua-platform=*, ch-ua-platform-version=*, ch-ua-model=*, ch-ua-full-version-list=*");

if (trackTracking) {
  const cookiesToSet = getMetaCookiesToSet(Astro.request);
  for (const cookie of cookiesToSet) {
    Astro.cookies.set(cookie.name, cookie.value, {
      path: "/",
      maxAge: cookie.maxAge ?? 7776000,
      sameSite: "lax",
      secure: Astro.url.protocol === "https:",
      httpOnly: cookie.httpOnly ?? false
    });
  }
  const trackingCookies = resolveTrackingCookies(Astro.request, cookiesToSet);
  hashedExternalId = trackingCookies.externalId ? await sha256Hex(trackingCookies.externalId) : undefined;

  defer(Astro, queueMetaEvent(env, Astro.request, link, {
    kind: "view",
    eventName: "PageView",
    eventId: pageViewEventId,
    cookies: trackingCookies
  }));
  defer(Astro, incrementDailyMetric(env, link.id, "views"));
  defer(Astro, recordMetricEvent(env, {
    linkId: link.id,
    kind: "view",
    request: Astro.request,
    cookies: trackingCookies
  }));
}

const baseUrl = publicBaseUrl(env, Astro.request).replace(/\/$/, "");
const artworkPath = artworkPublicPath(link.track);
const artwork = artworkPath.startsWith("http") ? artworkPath : `${baseUrl}${artworkPath}`;
const paletteVars = parseTrackPalette(link.track.palette);
const pageStyle = `${paletteStyleAttribute(paletteVars)}; --artwork-image: url("${artwork.replace(/["\\\n\r]/g, "")}")`;
const releaseAt = link.track.release_at;
const isPresave = effectiveMode === "presave";
const pixelScript = trackTracking
  ? buildPixelScript({ pixelId, pageViewEventId, externalId: hashedExternalId })
  : null;
const pageTitle = `${link.track.title} — ${link.track.artist_name}`;
const description = isPresave
  ? `Pre-save ${link.track.title} by ${link.track.artist_name}.`
  : `Listen to ${link.track.title} by ${link.track.artist_name}.`;
const pageUrl = `${baseUrl}/${link.slug}${isDraftPreview ? "?preview=1" : ""}`;

const countdownFallback = releaseAt
  ? `Releases ${formatShortDate(releaseAt)}`
  : "Release date coming soon";

const sortedDestinations = [...link.destinations].sort((a, b) => {
  if (a.platform === "spotify") return -1;
  if (b.platform === "spotify") return 1;
  return a.sort_order - b.sort_order;
});

const conversionValue = getMetaConversionValue(env);
const conversionCurrency = conversionValue === undefined ? undefined : getMetaCurrency(env);

const destinationRows = sortedDestinations.map((destination) => {
  const kind = isPresave ? "presave" : "click";
  const clickEventId = createEventId(kind, link, destination.platform);
  const paidClickEventId = !isPresave && paidAttribution ? paidEventId(clickEventId) : "";
  const outboundSuffix = trackingQuerySuffix(Astro.url, { eid: clickEventId });
  const cta = presaveDestinationLabel(destination.label, effectiveMode);
  const fallbackUrl = spotifyDestinationUrl(link, destination);
  const appUri = !isPresave && destination.platform === "spotify" && link.spotify_open_behavior === "app_first"
    ? spotifyAppUri(destination.url, link.spotify_context_url)
    : null;
  const payload = {
    action: isPresave ? "pre_save" : "musicservice",
    servicename: destination.platform,
    content_name: link.track.title,
    content_category: "music",
    content_ids: [link.track.isrc ?? link.slug],
    content_type: "music",
    artist: link.track.artist_name,
    artists: link.track.artist_names,
    song_name: link.track.title,
    slug: link.slug,
    platform: destination.platform,
    link_type: isPresave ? "pre_release" : "post_release",
    cta,
    value: conversionValue,
    currency: conversionCurrency
  };

  return {
    destination,
    cta,
    eventId: clickEventId,
    eventName: clickEventName,
    eventMethod: clickEventMethod,
    eventPayload: JSON.stringify(payload),
    paidEventName: paidClickEventId ? paidClickEventName : "",
    paidEventMethod: paidClickEventId ? paidClickEventMethod : "",
    paidEventId: paidClickEventId,
    href: `/out/${link.slug}/${destination.platform}${outboundSuffix}`,
    fallbackUrl,
    appUri
  };
});
---

<LinkLayout
  title={pageTitle}
  description={description}
  ogTitle={pageTitle}
  ogDescription={description}
  ogImage={artwork}
  ogUrl={pageUrl}
  twitterCard="summary_large_image"
  bodyClass={embedded ? "beamlink-link--embedded" : ""}
>
  {isDraftPreview && (
    <div class="draft-ribbon" role="status">
      Draft preview
    </div>
  )}

  <main class:list={["smart-page", embedded && "smart-page--embedded"]} style={pageStyle}>
    <div class="artwork-bg" aria-hidden="true"></div>
    <div class="page-scrim" aria-hidden="true"></div>

    <section class="release">
      <img
        class="artwork"
        src={artwork}
        alt={`${link.track.title} cover art`}
        width="640"
        height="640"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="copy">
        <p class="mode">{isPresave ? "Pre-save" : "Listen now"}</p>
        <h1>{link.track.title}</h1>
        <p class="artist">{link.track.artist_name}</p>
        {link.track.isrc && <p class="isrc">ISRC {link.track.isrc}</p>}
        {isPresave && (
          <p class="countdown" data-release-at={releaseAt ?? ""} aria-live="polite">
            {countdownFallback}
          </p>
        )}
      </div>
    </section>

    {isPresave && (
      <form class="subscribe" id="subscribeForm">
        <label for="email">Email for release day reminder</label>
        <div class="subscribe-row">
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
            inputmode="email"
          />
          <button class="button subscribe-submit" type="submit">Notify me</button>
        </div>
        <p class="subscribe-status muted" id="subscribeStatus" role="status" aria-live="polite"></p>
      </form>
    )}

    <nav class={`destinations count-${destinationRows.length}`} aria-label="Streaming platforms">
      {destinationRows.map((row) => (
        <a
          class:list={[
            "destination",
            row.destination.platform === "spotify" && "destination--spotify",
            row.destination.is_primary === 1 && "destination--primary"
          ]}
          href={row.href}
          data-track-click
          data-event-id={row.eventId}
          data-event-name={row.eventName}
          data-event-method={row.eventMethod}
          data-event-payload={row.eventPayload}
          data-paid-event-name={row.paidEventName}
          data-paid-event-method={row.paidEventMethod}
          data-paid-event-id={row.paidEventId}
          data-fallback-url={row.fallbackUrl}
          data-app-uri={row.appUri ?? ""}
        >
          <PlatformIcon platform={row.destination.platform} size={22} />
          <span>{row.cta}</span>
          <svg class="chevron" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 4l6 6-6 6" /></svg>
        </a>
      ))}
    </nav>
  </main>

  {pixelScript && <script is:inline set:html={pixelScript}></script>}

  {trackTracking && pixelId && (
    <script is:inline>
      function collectClickDeviceParams() {
        const screenWidth = Math.round(window.screen?.width || 0);
        const screenHeight = Math.round(window.screen?.height || 0);
        const viewportWidth = Math.round(window.innerWidth || 0);
        const viewportHeight = Math.round(window.innerHeight || 0);
        return {
          sr: screenWidth && screenHeight ? `${screenWidth}x${screenHeight}` : "",
          vp: viewportWidth && viewportHeight ? `${viewportWidth}x${viewportHeight}` : "",
          dpr: window.devicePixelRatio ? String(window.devicePixelRatio) : "",
          tz: String(new Date().getTimezoneOffset()),
          lang: navigator.language || ""
        };
      }

      document.addEventListener("click", (event) => {
        const anchor = event.target?.closest?.("a[data-track-click]");
        if (!anchor) return;

        function withDeviceParams(rawHref, extra = {}) {
          const url = new URL(rawHref);
          for (const [key, value] of Object.entries(collectClickDeviceParams())) {
            if (value) url.searchParams.set(key, value);
          }
          for (const [key, value] of Object.entries(extra)) {
            if (value) url.searchParams.set(key, value);
          }
          return url.toString();
        }

        try {
          anchor.href = withDeviceParams(anchor.href);
        } catch {
          // Keep the outbound click working if URL mutation fails.
        }

        function payloadFromAnchor() {
          try {
            return JSON.parse(anchor.dataset.eventPayload || "{}");
          } catch {
            return {};
          }
        }

        function firePixelEvent(eventName, eventId, method) {
          if (!eventName || !eventId || typeof window.fbq !== "function") return;
          fbq(method || "trackCustom", eventName, payloadFromAnchor(), { eventID: eventId });
        }

        firePixelEvent(anchor.dataset.eventName, anchor.dataset.eventId, anchor.dataset.eventMethod);
        firePixelEvent(anchor.dataset.paidEventName, anchor.dataset.paidEventId, anchor.dataset.paidEventMethod);

        const appUri = anchor.dataset.appUri;
        if (!appUri) return;

        event.preventDefault();
        let trackingUrl = anchor.href;
        try {
          trackingUrl = withDeviceParams(anchor.href, { track_only: "1" });
        } catch {
          trackingUrl = anchor.href.includes("?") ? `${anchor.href}&track_only=1` : `${anchor.href}?track_only=1`;
        }
        try {
          fetch(trackingUrl, { method: "GET", credentials: "include", keepalive: true });
        } catch {
          // Browser pixel already fired above; keep the tap moving.
        }

        let leftPage = false;
        const markLeft = () => { leftPage = true; };
        window.addEventListener("pagehide", markLeft, { once: true });
        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") markLeft();
        }, { once: true });

        window.location.href = appUri;
        window.setTimeout(() => {
          if (!leftPage && document.visibilityState !== "hidden") {
            window.location.href = anchor.dataset.fallbackUrl || anchor.href;
          }
        }, 1100);
      }, { capture: true });
    </script>
  )}

  {isPresave && releaseAt && (
    <script is:inline define:vars={{ releaseAt }}>
      const countdown = document.querySelector(".countdown");
      const target = new Date(releaseAt).getTime();
      if (!Number.isNaN(target)) {
        function tick() {
          const diff = Math.max(0, target - Date.now());
          const days = Math.floor(diff / 86400000);
          const hours = Math.floor((diff % 86400000) / 3600000);
          const minutes = Math.floor((diff % 3600000) / 60000);
          const seconds = Math.floor((diff % 60000) / 1000);
          if (countdown) {
            countdown.textContent = diff <= 0
              ? "Out now — refreshing…"
              : `Releases in ${days}d ${hours}h ${minutes}m ${seconds}s`;
          }
          if (diff <= 0) location.reload();
        }
        tick();
        setInterval(tick, 1000);
      }
    </script>
  )}

  {isPresave && (
    <script is:inline define:vars={{ linkId: link.id }}>
      const form = document.querySelector("#subscribeForm");
      const status = document.querySelector("#subscribeStatus");
      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (status) status.textContent = "Saving…";
        const email = document.querySelector("#email")?.value?.trim() ?? "";
        const response = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ linkId, email })
        });
        const data = await response.json().catch(() => ({}));
        if (status) {
          status.textContent = response.ok
            ? "You're on the list."
            : data.error || "Could not subscribe.";
        }
      });
    </script>
  )}
</LinkLayout>

<style>
  .draft-ribbon {
    position: fixed;
    top: 0.75rem;
    left: 50%;
    z-index: 30;
    translate: -50% 0;
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    background: var(--warn, oklch(0.78 0.15 70));
    color: oklch(0.18 0.02 70);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 6px 18px oklch(0 0 0 / 0.28);
  }

  .smart-page {
    position: relative;
    width: min(30rem, calc(100% - 2rem));
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    margin-inline: auto;
    padding-block: 1.75rem;
    isolation: isolate;
  }

  :global(.beamlink-link--embedded) {
    min-height: 0;
    overflow: hidden;
    background: var(--background);
  }

  .smart-page--embedded {
    width: min(100% - 1.5rem, 24rem);
    min-height: 0;
    justify-content: start;
    gap: 0.8rem;
    padding-block: 1.25rem;
  }

  .artwork-bg {
    position: fixed;
    inset: -7rem;
    z-index: -2;
    background:
      linear-gradient(180deg, oklch(0.1 0.01 260 / 0.16), var(--page-tint, var(--background)) 86%),
      var(--artwork-image);
    background-position: center;
    background-size: cover;
    filter: blur(3.8rem) saturate(1.38) brightness(1.22);
    transform: scale(1.12);
    opacity: 0.95;
  }

  .smart-page--embedded .artwork-bg {
    position: absolute;
    inset: -4rem -3rem;
    filter: blur(3rem) saturate(1.28) brightness(1.14);
    transform: scale(1);
  }

  .page-scrim {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(180deg, oklch(0.02 0.006 260 / 0.28), oklch(0.02 0.006 260 / 0.6)),
      oklch(0.06 0.01 260 / calc(var(--scrim-opacity, 0.72) * 0.62));
  }

  .smart-page--embedded .page-scrim {
    position: absolute;
    inset: -1.5rem;
  }

  .release {
    display: grid;
    justify-items: center;
    gap: 1rem;
    text-align: center;
  }

  .artwork {
    width: min(74vw, 18rem);
    height: min(74vw, 18rem);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 16px;
    background: var(--surface);
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.12) inset,
      0 0 0 1px oklch(0 0 0 / 0.35),
      0 24px 60px -18px oklch(0 0 0 / 0.7);
  }

  .smart-page--embedded .artwork {
    width: min(58vw, 13rem);
    height: min(58vw, 13rem);
    border-radius: 14px;
  }

  .copy {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
    max-width: 22rem;
  }

  .mode,
  .isrc,
  .artist,
  .countdown {
    margin: 0;
  }

  .mode {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  h1 {
    margin: 0;
    max-width: 15ch;
    font-size: clamp(1.65rem, 5.4vw, 2.35rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .smart-page--embedded h1 {
    font-size: clamp(1.45rem, 8vw, 1.9rem);
  }

  .artist {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .isrc,
  .countdown {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .subscribe {
    display: grid;
    gap: 0.55rem;
    width: 100%;
  }

  .subscribe label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .subscribe-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
  }

  .subscribe-row input {
    min-width: 0;
    min-height: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.65rem 0.75rem;
    background: var(--surface);
    color: var(--foreground);
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .subscribe-row input::placeholder {
    color: var(--muted);
    opacity: 1;
  }

  .subscribe-submit {
    border-radius: 12px;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .subscribe-submit:hover {
    filter: brightness(1.04);
  }

  .subscribe-status {
    margin: 0;
    min-height: 1.2rem;
    font-size: 0.8rem;
  }

  .destinations {
    display: grid;
    gap: 0.55rem;
    width: 100%;
    margin-top: 0.15rem;
  }

  .destination {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.8rem;
    min-height: 3.5rem;
    padding: 0.72rem 0.95rem 0.72rem 0.9rem;
    border-radius: 14px;
    border: 1px solid oklch(0.98 0.004 265 / 0.14);
    background: oklch(0.22 0.006 265 / 0.55);
    color: var(--foreground);
    font-size: 0.95rem;
    font-weight: 600;
    backdrop-filter: blur(14px) saturate(1.1);
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .smart-page--embedded .destination {
    min-height: 3.2rem;
    padding-block: 0.62rem;
    border-radius: 12px;
    font-size: 0.9rem;
  }

  .destination > span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .destination .chevron {
    flex-shrink: 0;
    color: oklch(0.98 0.004 265 / 0.5);
    transition: transform 180ms ease, color 180ms ease;
  }

  .destination:hover {
    transform: translateY(-1px);
    background: oklch(0.29 0.006 265 / 0.7);
    border-color: oklch(0.98 0.004 265 / 0.28);
  }

  .destination:hover .chevron {
    transform: translateX(2px);
    color: var(--foreground);
  }

  /* Priority destination (Spotify / first) — solid, high-contrast to drive the tap. */
  .destination:first-child {
    background: oklch(0.97 0.005 265);
    border-color: transparent;
    color: oklch(0.17 0.006 265);
    box-shadow: 0 8px 24px -12px oklch(0 0 0 / 0.6);
  }

  .destination:first-child .chevron {
    color: oklch(0.17 0.006 265 / 0.55);
  }

  .destination:first-child:hover {
    background: oklch(1 0 0);
  }

  .destination:first-child:hover .chevron {
    color: oklch(0.17 0.006 265);
  }

  .destinations.count-1 .destination {
    min-height: 3.75rem;
    font-size: 1rem;
  }

  .destination:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 2px;
  }

  .destination:first-child:focus-visible {
    outline-color: oklch(0.17 0.006 265);
  }

  .subscribe-row input:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 2px;
  }

  /* Entrance is an enhancement layered over content that is visible by default. */
  @media (prefers-reduced-motion: no-preference) {
    .release,
    .subscribe,
    .destinations {
      animation: rise 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .release {
      animation-delay: 40ms;
    }

    .subscribe {
      animation-delay: 130ms;
    }

    .destinations {
      animation-delay: 200ms;
    }

    .artwork {
      animation: artwork-in 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }

  @keyframes artwork-in {
    from {
      opacity: 0;
      transform: scale(0.94);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .destination:hover,
    .subscribe-submit:hover {
      transform: none;
    }

    .destination:hover .chevron {
      transform: none;
    }
  }
</style>
