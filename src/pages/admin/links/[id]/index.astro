---
import AppLayout from "@layouts/AppLayout.astro";
import AdminLinkNav from "@components/AdminLinkNav.astro";
import Button from "@components/Button.astro";
import Chart from "@components/Chart.astro";
import HourHeatmap from "@components/HourHeatmap.astro";
import BreakdownList from "@components/BreakdownList.astro";
import AnalyticsTabs from "@components/AnalyticsTabs.astro";
import MetaCampaignTable from "@components/MetaCampaignTable.astro";
import CollapsibleSection from "@components/CollapsibleSection.astro";
import Icon from "@components/Icon.astro";
import PlatformIcon from "@components/PlatformIcon.astro";
import SettingsModal from "@components/SettingsModal.astro";
import SubscriberManager from "@components/SubscriberManager.astro";
import ScreenshotSafeToggle from "@components/ScreenshotSafeToggle.astro";
import { getLinkById, listSubscribers } from "@lib/db";
import { getRuntimeEnv, requireAdmin, publicBaseUrl } from "@lib/runtime";
import { effectiveLinkMode, daysUntilRelease } from "@lib/effective-mode";
import {
  getAdBreakdown,
  getBrowserBreakdown,
  getCampaignBreakdown,
  getCityBreakdown,
  getDeviceBreakdown,
  getFunnelStats,
  getGeoBreakdown,
  getHourHeatmap,
  getHourlyTimeseries,
  getLinkCampaignAttribution,
  getLinkTimeseries,
  getOsBreakdown,
  getPlacementBreakdown,
  getPlatformClicks,
  getReferrerBreakdown,
  getUniqueTimeseries,
  getUniqueVisitors,
  normalizeAnalyticsOptions
} from "@lib/stats";
import { artworkPublicPath } from "@lib/artwork";
import { platformBrandColors } from "@lib/platform-brand";
import { getMetaAccessToken, getMetaAdAccountId, getMetaConversionValue, getMetaCurrency, getMetaPixelId, metaEventsManagerUrl } from "@lib/settings";
import {
  analyzeCapiMatchKeys,
  countSentCapiConversions,
  countSentCapiByEventName,
  getCapiDeliveryStats,
  listCapiLogsByLink,
  parseCapiLogView
} from "@lib/capi-log";
import { formatMatchKeyLabel, getMetaDatasetQuality, pickMetaEventQuality } from "@lib/meta-quality";
import {
  buildCampaignPerformance,
  getMetaAdsInsights,
  resolveCampaignNames
} from "@lib/meta-ads-insights";
import { resolveClickEventName, resolveViewEventName } from "@lib/effective-mode";
import { platformLabels } from "@lib/types";

const env = getRuntimeEnv(Astro);
const blocked = await requireAdmin(Astro.request, env);
if (blocked) return blocked;

const link = await getLinkById(env, Astro.params.id ?? "");
if (!link) return Astro.redirect("/admin", 302);
const subscribers = await listSubscribers(env, link.id);

const baseUrl = publicBaseUrl(env, Astro.request).replace(/\/$/, "");
const publicUrl = `${baseUrl}/${link.slug}`;
const previewUrl = `${publicUrl}?preview=1`;
const options = normalizeAnalyticsOptions(Astro.url.searchParams);
const isHourly = options.granularity === "hourly";
const conversionValue = getMetaConversionValue(env);
const currency = getMetaCurrency(env);
const clickEventName = resolveClickEventName(link);
const viewEventName = resolveViewEventName(link);
const metaDays = isHourly ? Math.max(1, Math.ceil(options.hours / 24)) : options.days;
const [funnel, timeseries, heatmap, platformClicks, geoRows, cityRows, campaignRows, linkCampaignAttribution, adRows, placementRows, referrerRows, deviceRows, browserRows, osRows, uniqueVisitors, pixelId, metaAccessToken, metaAdAccountId, linkCapiLogs, capiDelivery, capiSentConversions, capiSentViewContent, capiSentLegacyStreamClick, metaQuality] = await Promise.all([
  getFunnelStats(env, link.id, options.days),
  isHourly
    ? getHourlyTimeseries(env, link.id, options.hours)
    : options.unique
      ? getUniqueTimeseries(env, link.id, options.days)
      : getLinkTimeseries(env, link.id, options.days),
  getHourHeatmap(env, link.id, options.days),
  getPlatformClicks(env, link.id),
  getGeoBreakdown(env, link.id, options.days),
  getCityBreakdown(env, link.id, options.days),
  getCampaignBreakdown(env, link.id, metaDays),
  getLinkCampaignAttribution(env, link.id, metaDays),
  getAdBreakdown(env, link.id, metaDays),
  getPlacementBreakdown(env, link.id, metaDays),
  getReferrerBreakdown(env, link.id, metaDays),
  getDeviceBreakdown(env, link.id, options.days),
  getBrowserBreakdown(env, link.id, options.days),
  getOsBreakdown(env, link.id, options.days),
  getUniqueVisitors(env, link.id, options.days),
  getMetaPixelId(env),
  getMetaAccessToken(env),
  getMetaAdAccountId(env),
  listCapiLogsByLink(env, link.id, 20, options.days),
  getCapiDeliveryStats(env, link.id, options.days),
  countSentCapiConversions(env, link.id, options.days, clickEventName),
  countSentCapiByEventName(env, link.id, clickEventName, options.days),
  countSentCapiByEventName(env, link.id, "Stream_Click", options.days),
  getMetaDatasetQuality(env)
]);
const metaAdsInsights = metaAdAccountId && metaAccessToken
  ? await getMetaAdsInsights(env, metaDays, clickEventName)
  : null;
const campaignNameOverrides = await resolveCampaignNames(
  env,
  linkCampaignAttribution.map((row) => row.campaignId).filter(Boolean)
);
const campaignPerformance = buildCampaignPerformance(linkCampaignAttribution, metaAdsInsights, campaignNameOverrides);
const campaignDisplayRows = campaignPerformance.map((row) => ({
  label: row.displayName,
  count: row.yourTaps,
  share: funnel.viewContents > 0 ? row.yourTaps / funnel.viewContents : 0
}));
const totalAdSpend = campaignPerformance.reduce((sum, row) => sum + (row.spend ?? 0), 0);
const adsInsightsConfigured = Boolean(metaAdAccountId && metaAccessToken);
const adsInsightsCurrency = metaAdsInsights?.currency ?? currency;
const tapRateLabel = funnel.pageViews > 0 ? `${(funnel.tapRate * 100).toFixed(1)}%` : "—";
const rangeLabel = isHourly
  ? (options.hours === 168 ? "Last 7 days · hourly" : `Last ${options.hours}h`)
  : `Last ${options.days} days`;
const uniqueLabel = options.unique ? "unique" : "total";
const platformTotal = platformClicks.reduce((sum, row) => sum + row.clicks, 0);
const platformBreakdownRows = platformClicks.map((row) => ({
  label: platformLabels[row.platform] ?? row.platform,
  count: row.clicks,
  share: platformTotal > 0 ? row.clicks / platformTotal : 0,
  platform: row.platform,
  brandColor: platformBrandColors[row.platform]
}));
const geoBreakdownRows = geoRows.map((row) => ({ label: row.country, count: row.count, share: row.share }));
const hasAttribution = campaignPerformance.length + adRows.length + placementRows.length + referrerRows.length > 0;
const audienceTabs = [
  { id: "platforms", label: "Platforms" },
  { id: "countries", label: "Countries" },
  { id: "cities", label: "Cities" },
  { id: "devices", label: "Devices" },
  { id: "tech", label: "Tech" }
];
const attributionTabs = [
  ...(adsInsightsConfigured ? [{ id: "meta-ads", label: "Meta ads" }] : []),
  { id: "campaigns", label: "Campaigns" },
  { id: "ads", label: "Ads" },
  { id: "placements", label: "Placements" },
  { id: "referrers", label: "Referrers" }
];
const attributionDefaultTab = adsInsightsConfigured ? "meta-ads" : "campaigns";

function formatCurrency(amount: number): string {
  try {
    return new Intl.NumberFormat("en-US", { style: "currency", currency, maximumFractionDigits: 2 }).format(amount);
  } catch {
    return `${amount.toFixed(2)} ${currency}`;
  }
}
const effectiveMode = effectiveLinkMode(link);
const days = daysUntilRelease(link.track.release_at);
const artistLabel = link.track.artist_name || "Unknown artist";
const pixelConnected = Boolean(pixelId);
const capiConnected = pixelConnected && Boolean(metaAccessToken);
const eventsManagerUrl = metaEventsManagerUrl(pixelId);
const capiMatchKeys = analyzeCapiMatchKeys(linkCapiLogs);
const clickEventQuality = pickMetaEventQuality(metaQuality, clickEventName);
const pageViewEventQuality = pickMetaEventQuality(metaQuality, viewEventName);
const capiDiagnostics = [...(clickEventQuality?.diagnostics ?? []), ...(pageViewEventQuality?.diagnostics ?? [])]
  .filter((item, index, items) => items.findIndex((other) => other.name === item.name) === index)
  .slice(0, 4);
const capiReconcileGap = funnel.viewContents - capiSentConversions;
const capiReconcileHint = capiReconcileGap === 0
  ? "Matches tap count"
  : capiReconcileGap > 0
    ? `${capiReconcileGap} tap(s) missing from CAPI log`
    : `${Math.abs(capiReconcileGap)} extra CAPI row(s)`;
const capiConversionDetail = capiSentLegacyStreamClick > 0
  ? `${capiSentViewContent} ${clickEventName} · ${capiSentLegacyStreamClick} legacy Stream_Click`
  : `${capiSentViewContent} ${clickEventName}`;
const matchKeyRows = [
  ["IP", capiMatchKeys.ip],
  ["UA", capiMatchKeys.userAgent],
  ["fbp", capiMatchKeys.fbp],
  ["fbc", capiMatchKeys.fbc],
  ["Ext ID", capiMatchKeys.externalId],
  ["Country", capiMatchKeys.country],
  ["City", capiMatchKeys.city],
  ["State", capiMatchKeys.state],
  ["ZIP", capiMatchKeys.zip],
  ["Email", capiMatchKeys.email]
] as const;
const metaFeedbackById = new Map(
  (clickEventQuality?.matchKeyFeedback ?? []).map((item) => [formatMatchKeyLabel(item.identifier), item.percentage])
);
const showMatchKeysOpen = capiDelivery.failed > 0 || (clickEventQuality?.emqScore ?? 10) < 7;
const showDiagnosticsOpen = capiDiagnostics.some((item) => (item.percentage ?? 0) > 5);
const artworkSrc = artworkPublicPath(link.track);
const modeBadge = effectiveMode === "presave"
  ? { label: `Pre-save${days !== null ? ` · ${days}d` : ""}`, variant: "presave" }
  : { label: "Live", variant: "live" };
const identityBadges = [modeBadge, { label: link.status, variant: link.status }];
const isDraft = link.status === "draft";
const directStreamLinks = link.destinations.map((destination) => ({
  platform: destination.platform,
  label: platformLabels[destination.platform] ?? destination.label,
  url: `${baseUrl}/d/${link.slug}/${destination.platform}`
}));

function hrefWith(overrides: Record<string, string>, removes: string[] = []): string {
  const params = new URLSearchParams(Astro.url.searchParams);
  for (const key of removes) params.delete(key);
  for (const [key, value] of Object.entries(overrides)) params.set(key, value);
  return `?${params.toString()}`;
}

function matchKeyShare(count: number, total: number): string {
  if (total <= 0) return "—";
  return `${Math.round((count / total) * 100)}%`;
}

function emqLabel(score: number | undefined): string {
  if (score === undefined) return "—";
  return `${score.toFixed(1)}/10`;
}
---

<AppLayout title={link.link_name}>
  <main class="admin-page shell">
    <AdminLinkNav
      linkId={link.id}
      slug={link.slug}
      linkName={link.link_name}
      trackTitle={link.track.title}
      artistName={artistLabel}
      activeTab="overview"
      artworkSrc={artworkSrc}
      badges={identityBadges}
    />

    <section class="action-bar" aria-label="Link actions">
      <div class="url-bar">
        <code data-sensitive>{publicUrl}</code>
        <Button variant="secondary" size="sm" id="copyUrl" type="button" aria-label="Copy public URL"><Icon name="copy" /> Copy</Button>
      </div>
      <div class="admin-toolbar action-buttons">
        <Button variant="accent" href={publicUrl} target="_blank" rel="noreferrer"><Icon name="open" /> Open link</Button>
        <Button variant="secondary" href={`/admin/links/${link.id}/edit`}><Icon name="edit" /> Edit</Button>
        <Button class="danger" id="deleteButton" type="button"><Icon name="trash" /> Delete</Button>
      </div>
    </section>

    {directStreamLinks.length > 0 && (
      <section class="section direct-links" aria-label="Direct stream links">
        <div class="panel-head">
          <h2 class="section-title">Direct stream links</h2>
        </div>
        <div class="direct-link-list">
          {directStreamLinks.map((item) => (
            <div class="direct-link-row">
              <span class="name"><PlatformIcon platform={item.platform} size={18} tint /><span>{item.label}</span></span>
              <code>{item.url}</code>
              <Button variant="secondary" size="sm" type="button" data-copy-url={item.url}>Copy</Button>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="admin-panel analytics-panel" aria-label="Analytics">
      <div class="metric-strip bare funnel-strip" aria-label="Funnel">
        <div class="metric">
          <span class="label">Page views</span>
          <span class="value accent">{funnel.pageViews}</span>
          <span class="sub muted">{rangeLabel} · {uniqueLabel}</span>
        </div>
        <div class="funnel-arrow" aria-hidden="true">→</div>
        <div class="metric">
          <span class="label">Stream taps</span>
          <span class="value success">{funnel.viewContents}</span>
          <span class="sub muted">
            {totalAdSpend > 0
              ? `Ad spend ${formatCurrency(totalAdSpend)}`
              : `CAPI ${formatCurrency(conversionValue)} / tap`}
          </span>
        </div>
        <div class="metric">
          <span class="label">Tap rate</span>
          <span class="value">{tapRateLabel}</span>
          <span class="sub muted">Views → taps</span>
        </div>
        <div class="metric">
          <span class="label">Unique visitors</span>
          <span class="value">{uniqueVisitors}</span>
          <span class="sub muted">Deduped people</span>
        </div>
      </div>

      <div class="panel-head chart-head">
        <div class="chart-title">
          <h2>Traffic over time</h2>
          <p class="muted panel-subtitle">
            {isHourly ? "Hourly" : "Daily"} · {rangeLabel.toLowerCase()} · {uniqueLabel} counts
          </p>
        </div>
        <div class="chart-controls analytics-toolbar">
          <div class="range-toggle" aria-label="Granularity">
            <a class:list={["range", !isHourly && "active"]} href={hrefWith({ granularity: "daily" }, ["hours"])} aria-current={!isHourly ? "true" : undefined}>Daily</a>
            <a class:list={["range", isHourly && "active"]} href={hrefWith({ granularity: "hourly" })} aria-current={isHourly ? "true" : undefined}>Hourly</a>
          </div>
          {isHourly ? (
            <div class="range-toggle" aria-label="Hour range">
              {([24, 48, 168] as const).map((hours) => (
                <a class:list={["range", options.hours === hours && "active"]} href={hrefWith({ granularity: "hourly", hours: String(hours) })} aria-current={options.hours === hours ? "true" : undefined}>{hours === 168 ? "7d" : `${hours}h`}</a>
              ))}
            </div>
          ) : (
            <div class="range-toggle" aria-label="Day range">
              {([7, 30, 90] as const).map((range) => (
                <a class:list={["range", options.days === range && "active"]} href={hrefWith({ granularity: "daily", range: String(range) }, ["hours"])} aria-current={options.days === range ? "true" : undefined}>{range}d</a>
              ))}
            </div>
          )}
          {!isHourly && (
            <div class="range-toggle" aria-label="Count mode">
              <a class:list={["range", !options.unique && "active"]} href={hrefWith({ unique: "0" })} aria-current={!options.unique ? "true" : undefined}>Total</a>
              <a class:list={["range", options.unique && "active"]} href={hrefWith({ unique: "1" })} aria-current={options.unique ? "true" : undefined}>Unique</a>
            </div>
          )}
        </div>
      </div>
      <Chart
        series={timeseries}
        labelFormat={isHourly ? "hour" : "day"}
        viewsLabel="Page views"
        clicksLabel="Stream taps"
        showDelta={!isHourly}
        ariaLabel={`Traffic chart for ${link.link_name}, ${rangeLabel}`}
      />
    </section>

    <CollapsibleSection id="peak-hours" title="Peak hours" subtitle={`ViewContent taps · ${rangeLabel} · UTC`} defaultOpen={true}>
      <HourHeatmap data={heatmap} ariaLabel={`Taps by hour and weekday for ${link.link_name}`} />
    </CollapsibleSection>

    <CollapsibleSection id="audience" title="Audience" subtitle={rangeLabel} defaultOpen={true}>
      <AnalyticsTabs groupId="audience" tabs={audienceTabs} activeId="platforms">
        <div data-tab-panel="platforms" id="audience-panel-platforms" role="tabpanel" aria-labelledby="audience-tab-platforms">
          <BreakdownList rows={platformBreakdownRows} empty="No platform clicks yet." />
        </div>
        <div data-tab-panel="countries" id="audience-panel-countries" role="tabpanel" hidden aria-labelledby="audience-tab-countries">
          <BreakdownList rows={geoBreakdownRows} empty="No country data yet." />
        </div>
        <div data-tab-panel="cities" id="audience-panel-cities" role="tabpanel" hidden aria-labelledby="audience-tab-cities">
          <BreakdownList rows={cityRows} empty="No city data yet." />
        </div>
        <div data-tab-panel="devices" id="audience-panel-devices" role="tabpanel" hidden aria-labelledby="audience-tab-devices">
          <BreakdownList rows={deviceRows} empty="No device data yet." />
        </div>
        <div data-tab-panel="tech" id="audience-panel-tech" role="tabpanel" hidden aria-labelledby="audience-tab-tech">
          <div class="tech-split">
            <div class="tech-block">
              <h3 class="tech-title">Browsers</h3>
              <BreakdownList rows={browserRows} empty="No browser data yet." limit={5} />
            </div>
            <div class="tech-block">
              <h3 class="tech-title">Operating systems</h3>
              <BreakdownList rows={osRows} empty="No OS data yet." limit={5} />
            </div>
          </div>
        </div>
      </AnalyticsTabs>
    </CollapsibleSection>

    <CollapsibleSection id="attribution" title="Attribution" subtitle={`Where ViewContent comes from · ${rangeLabel}`} defaultOpen={hasAttribution || adsInsightsConfigured}>
      {hasAttribution || adsInsightsConfigured ? (
        <AnalyticsTabs groupId="attribution" tabs={attributionTabs} activeId={attributionDefaultTab}>
          {adsInsightsConfigured && (
            <div data-tab-panel="meta-ads" id="attribution-panel-meta-ads" role="tabpanel" aria-labelledby="attribution-tab-meta-ads">
              <MetaCampaignTable
                rows={campaignPerformance}
                currency={adsInsightsCurrency}
                error={metaAdsInsights?.error}
                fetchedAt={metaAdsInsights?.fetchedAt}
                empty="No campaign taps on this link in range. Add campaign_id={{campaign.id}} to your ad URL."
              />
              <p class="attribution-hint muted">
                Spend and results from Meta Ads API · your taps from first-party logs. Token needs <code>ads_read</code> and <code>read_insights</code>.
              </p>
            </div>
          )}
          <div data-tab-panel="campaigns" id="attribution-panel-campaigns" role="tabpanel" hidden={attributionDefaultTab !== "campaigns"} aria-labelledby="attribution-tab-campaigns">
            <BreakdownList rows={campaignDisplayRows.length > 0 ? campaignDisplayRows : campaignRows} empty="No campaign data yet." sensitive />
            <p class="attribution-hint muted">
              Use <code>campaign_id={"{{campaign.id}}"}</code> and <code>utm_campaign={"{{campaign.name}}"}</code> on your ad URL for names + Meta join.
            </p>
          </div>
          <div data-tab-panel="ads" id="attribution-panel-ads" role="tabpanel" hidden aria-labelledby="attribution-tab-ads">
            <BreakdownList rows={adRows} empty="No ad data yet." sensitive />
            <p class="attribution-hint muted">Add <code>ad_id={"{{ad.id}}"}</code> to your ad URL.</p>
          </div>
          <div data-tab-panel="placements" id="attribution-panel-placements" role="tabpanel" hidden aria-labelledby="attribution-tab-placements">
            <BreakdownList rows={placementRows} empty="No placement data yet." sensitive />
            <p class="attribution-hint muted">Add <code>placement={"{{placement}}"}</code> to your ad URL.</p>
          </div>
          <div data-tab-panel="referrers" id="attribution-panel-referrers" role="tabpanel" hidden aria-labelledby="attribution-tab-referrers">
            <BreakdownList rows={referrerRows} empty="No referrer data yet." />
            <p class="attribution-hint muted">Where the tap came from before your link page.</p>
          </div>
        </AnalyticsTabs>
      ) : (
        <p class="muted empty-line">No campaign, ad, or referrer data yet. Add URL parameters to your ads (e.g. <code>utm_campaign</code>, <code>ad_id={"{{ad.id}}"}</code>, <code>placement={"{{placement}}"}</code>) so this fills in.</p>
      )}
    </CollapsibleSection>

    <CollapsibleSection id="meta-delivery" title="Meta delivery & quality" subtitle={`${rangeLabel} · CAPI logs + dataset quality`} defaultOpen={capiConnected}>
      <div class="panel-head tracking-head">
        <div class="tracking-actions">
          <ScreenshotSafeToggle id="screenshotSafeModeOverview" compact />
          {eventsManagerUrl && (
            <Button variant="ghost" size="sm" href={eventsManagerUrl} target="_blank" rel="noreferrer" data-sensitive>
              Events Manager
            </Button>
          )}
          <Button class="icon-only" variant="ghost" size="sm" href="/admin/settings" data-settings-open aria-haspopup="dialog" title="Tracking settings" aria-label="Open tracking settings"><Icon name="settings" /></Button>
        </div>
      </div>

      <div class={`tracking-status ${capiConnected ? "ok" : pixelConnected ? "warn" : "muted"}`}>
        <span class="dot" aria-hidden="true"></span>
        <p>
          {capiConnected
            ? "CAPI connected. Server events below mirror what was queued for Meta."
            : pixelConnected
              ? "Pixel set, token missing. Browser PageView may still fire; CAPI is paused."
              : "Not connected. First-party analytics only."}
        </p>
      </div>

      {capiConnected && (
        <div class="meta-delivery-strip">
          <div class="metric">
            <span class="label">CAPI sent</span>
            <span class="value success">{capiDelivery.sent}</span>
            <span class="sub muted">{capiDelivery.total > 0 ? `${(capiDelivery.successRate * 100).toFixed(0)}% success` : "No sends"}</span>
          </div>
          <div class="metric">
            <span class="label">CAPI failed</span>
            <span class={`value ${capiDelivery.failed > 0 ? "warn-text" : ""}`}>{capiDelivery.failed}</span>
            <span class="sub muted">{capiDelivery.retried > 0 ? `${capiDelivery.retried} retried` : "Retries every 15 min"}</span>
          </div>
          <div class="metric">
            <span class="label">CAPI conversions</span>
            <span class="value">{capiSentConversions}</span>
            <span class={`sub ${Math.abs(capiReconcileGap) > 0 ? "warn-text" : "muted"}`}>{capiReconcileHint}</span>
            <span class="sub muted">{capiConversionDetail}</span>
          </div>
          <div class="metric">
            <span class="label">EMQ · {clickEventName}</span>
            <span class="value">{emqLabel(clickEventQuality?.emqScore)}</span>
            <span class="sub muted">
              {clickEventQuality?.eventCoverage !== undefined
                ? `${clickEventQuality.eventCoverage.toFixed(0)}% pixel · ${viewEventName} ${emqLabel(pageViewEventQuality?.emqScore)}`
                : `PageView ${emqLabel(pageViewEventQuality?.emqScore)}`}
            </span>
          </div>
        </div>
      )}

      {capiConnected && capiMatchKeys.total > 0 && (
        <details class="meta-details" open={showMatchKeysOpen}>
          <summary class="meta-details-summary">Match key coverage</summary>
          <p class="muted meta-panel-copy">Your sent payloads vs Meta dataset-wide coverage. Enable Cloudflare → Rules → Managed transforms → <strong>Add visitor location headers</strong> for better geo.</p>
          <div class="admin-table-wrap">
            <table class="admin-table match-key-table">
              <thead>
                <tr><th>Identifier</th><th>Your sends</th><th>Meta dataset</th></tr>
              </thead>
              <tbody>
                {matchKeyRows.map(([label, count]) => (
                  <tr>
                    <td>{label}</td>
                    <td class="tabular-nums">{matchKeyShare(Number(count), capiMatchKeys.total)}</td>
                    <td class="tabular-nums">{metaFeedbackById.has(label) ? `${metaFeedbackById.get(label)!.toFixed(0)}%` : "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      )}

      {capiConnected && capiDiagnostics.length > 0 && (
        <details class="meta-details" open={showDiagnosticsOpen}>
          <summary class="meta-details-summary">Meta diagnostics</summary>
          {capiDiagnostics.map((item) => (
            <div class="diagnostic-row">
              <strong>{item.name}</strong>
              <p class="muted">{item.description}</p>
              {item.solution && <p class="diagnostic-solution">{item.solution}</p>}
            </div>
          ))}
        </details>
      )}

      {capiConnected && metaQuality?.error && (
        <p class="muted empty-line">Could not load Meta dataset quality: {metaQuality.error}</p>
      )}

      {linkCapiLogs.length > 0 ? (
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr><th>Time</th><th>Event</th><th>Platform</th><th>Match keys</th><th>Status</th><th>Detail</th></tr>
            </thead>
            <tbody>
              {linkCapiLogs.map((row) => {
                const view = parseCapiLogView(row);
                return (
                  <tr>
                    <td class="tabular-nums">{row.created_at.slice(0, 19)}</td>
                    <td>
                      <div class="event-cell">
                        <span>{view.eventName}</span>
                        {view.attribution && <span class="muted event-sub" data-sensitive>{view.attribution}</span>}
                      </div>
                    </td>
                    <td>{view.platform ?? "—"}</td>
                    <td>
                      <div class="match-badges">
                        {view.matchKeys.length > 0
                          ? view.matchKeys.map((key) => <span class="match-badge">{key}</span>)
                          : <span class="muted">—</span>}
                      </div>
                    </td>
                    <td class={row.status}>{row.status}</td>
                    <td class="detail-cell" data-sensitive>{row.error_message ?? row.meta_trace_id ?? row.http_status ?? "—"}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ) : capiConnected ? (
        <p class="muted empty-line">No CAPI log rows for this link in {rangeLabel.toLowerCase()}. Traffic may be pre-deploy or bots were filtered.</p>
      ) : null}
    </CollapsibleSection>

    <SubscriberManager linkId={link.id} subscribers={subscribers} />

    <section class="section footer-actions">
      <div class="admin-toolbar">
        {isDraft && <Button variant="accent" id="publishButton" type="button">Publish link</Button>}
        <Button variant="secondary" href={previewUrl} target="_blank" rel="noreferrer"><Icon name="open" /> Draft preview</Button>
        <Button variant="secondary" href={`/api/admin/links/${link.id}/subscribers`}>Export subscribers</Button>
        {!isDraft && <Button variant="secondary" id="publishButton" type="button">Republish</Button>}
        <Button variant="ghost" id="archiveButton" type="button"><Icon name="archive" /> Archive</Button>
      </div>
      <p class="muted action-status" id="actionStatus" aria-live="polite"></p>
    </section>
  </main>

  <SettingsModal />

  <script is:inline define:vars={{ linkId: link.id, publicUrl, trackId: link.track_id, linkName: link.link_name, slug: link.slug, mode: link.mode, destinations: JSON.stringify(Object.fromEntries(link.destinations.map((d) => [d.platform, d.url]))) }}>
    const copyUrl = document.querySelector("#copyUrl");
    const actionStatus = document.querySelector("#actionStatus");
    const publishButton = document.querySelector("#publishButton");
    const archiveButton = document.querySelector("#archiveButton");
    const deleteButton = document.querySelector("#deleteButton");

    copyUrl?.addEventListener("click", async () => {
      await navigator.clipboard.writeText(publicUrl);
      copyUrl.textContent = "Copied";
      setTimeout(() => { copyUrl.textContent = "Copy"; }, 1200);
    });

    for (const button of document.querySelectorAll("[data-copy-url]")) {
      button.addEventListener("click", async () => {
        const value = button.dataset.copyUrl;
        if (!value) return;
        await navigator.clipboard.writeText(value);
        const label = button.textContent || "Copy";
        button.textContent = "Copied";
        setTimeout(() => { button.textContent = label; }, 1200);
      });
    }

    publishButton?.addEventListener("click", async () => {
      actionStatus.textContent = "Publishing…";
      const response = await fetch(`/api/admin/links/${linkId}/publish`, { method: "POST" });
      const data = await response.json();
      actionStatus.textContent = response.ok
        ? `Published at /${data.link.slug}.`
        : data.error || "Publish failed.";
    });

    archiveButton?.addEventListener("click", async () => {
      actionStatus.textContent = "Archiving…";
      const response = await fetch(`/api/admin/links/${linkId}`, {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          trackId,
          linkName,
          slug,
          mode,
          destinations: JSON.parse(destinations),
          status: "archived"
        })
      });
      const data = await response.json();
      actionStatus.textContent = response.ok ? "Archived." : data.error || "Archive failed.";
    });

    deleteButton?.addEventListener("click", async () => {
      const confirmed = prompt(`Delete “${linkName}”? This removes the link and its analytics. Type DELETE to continue.`);
      if (confirmed !== "DELETE") return;
      const response = await fetch(`/api/admin/links/${linkId}`, { method: "DELETE" });
      if (response.ok) {
        window.location.href = "/admin";
        return;
      }
      const data = await response.json().catch(() => ({}));
      actionStatus.textContent = data.error || "Delete failed.";
    });
  </script>
</AppLayout>

