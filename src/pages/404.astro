---
import LinkLayout from "@layouts/LinkLayout.astro";
---

<LinkLayout title="Link not found">
  <main class="shell not-found">
    <h1>Link not found</h1>
    <p class="muted">The music link is unavailable or has not been published.</p>
  </main>
</LinkLayout>

<style>
  .not-found {
    min-height: 100dvh;
    display: grid;
    align-content: center;
    gap: 0.5rem;
  }

  h1 {
    margin: 0;
    font-size: 2rem;
    letter-spacing: 0;
  }
</style>
