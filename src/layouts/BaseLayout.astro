---
import "../styles/global.css";
import { PRODUCT_NAME } from "@lib/brand";

export interface LayoutHeadProps {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  twitterCard?: "summary" | "summary_large_image" | "app" | "player";
  noindex?: boolean;
}

interface Props extends LayoutHeadProps {
  surface?: "admin" | "marketing" | "link";
  bodyClass?: string;
  fontPreload?: string;
  fontHref?: string;
}

const {
  title,
  description = "Fast first-party music smartlinks.",
  ogTitle,
  ogDescription = description,
  ogImage,
  ogUrl,
  twitterCard = ogImage ? "summary_large_image" : "summary",
  noindex = false,
  surface = "admin",
  bodyClass = "",
  fontPreload,
  fontHref
} = Astro.props;

function formatPageTitle(raw: string): string {
  if (new RegExp(`^${PRODUCT_NAME}\\s[—-]\\s`).test(raw)) return raw;
  const cleaned = raw.replace(new RegExp(`\\s*·\\s*${PRODUCT_NAME}\\s*$`, "i"), "").trim();
  return `${PRODUCT_NAME} — ${cleaned}`;
}

const pageTitle = formatPageTitle(title);
const socialTitle = ogTitle ?? pageTitle;
const bodyClasses = [bodyClass].filter(Boolean).join(" ");
---

<!doctype html>
<html lang="en" data-surface={surface}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={ogDescription} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {ogUrl && <link rel="canonical" href={ogUrl} />}
    {fontPreload && <link rel="preload" as="style" href={fontPreload} />}
    {fontHref && <link rel="stylesheet" href={fontHref} />}
  </head>
  <body class={bodyClasses}>
    <slot />
  </body>
</html>
