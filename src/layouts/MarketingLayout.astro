---
import "../styles/global.css";
import "../styles/marketing.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Self-hosted music smartlinks and presaves with edge speed and first-party Meta CAPI, built for indie labels running ads."
} = Astro.props;

const pageTitle = /^Beamlink\s[—-]\s/.test(title)
  ? title
  : `Beamlink — ${title.replace(/\s*·\s*Beamlink\s*$/i, "").trim()}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <div class="marketing">
      <div class="m-backdrop" aria-hidden="true">
        <div class="m-aurora">
          <span class="m-aurora-blob m-aurora-blob--1"></span>
          <span class="m-aurora-blob m-aurora-blob--2"></span>
          <span class="m-aurora-blob m-aurora-blob--3"></span>
          <span class="m-aurora-blob m-aurora-blob--4"></span>
        </div>
        <div class="m-vignette"></div>
      </div>
      <slot />
    </div>
    <script is:inline>
      (() => {
        const nav = document.querySelector(".m-nav");
        const onScroll = () => nav?.classList.toggle("is-scrolled", window.scrollY > 8);
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        // Parallax: aurora and dot grid drift slower than the page.
        const aurora = document.querySelector(".m-aurora");
        if (aurora) {
          let ticking = false;
          const onParallax = () => {
            const y = window.scrollY;
            if (aurora) aurora.style.transform = `translate3d(0, ${y * 0.28}px, 0)`;
            ticking = false;
          };
          onParallax();
          window.addEventListener(
            "scroll",
            () => {
              if (!ticking) {
                requestAnimationFrame(onParallax);
                ticking = true;
              }
            },
            { passive: true }
          );
        }

        const items = document.querySelectorAll("[data-reveal]");
        if (!items.length) return;

        const inView = (el) => {
          const rect = el.getBoundingClientRect();
          return rect.top < window.innerHeight - 32 && rect.bottom > 0;
        };

        for (const el of items) {
          if (inView(el)) el.classList.add("is-visible");
        }

        document.documentElement.classList.add("m-reveal-ready");

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.08, rootMargin: "0px 0px -24px 0px" }
        );

        for (const el of items) {
          if (!el.classList.contains("is-visible")) io.observe(el);
        }
      })();
    </script>
  </body>
</html>
