---
import AppLayout from "@layouts/AppLayout.astro";

interface Props {
  title: string;
  backHref?: string;
  backLabel?: string;
  lede?: string;
  fullWidth?: boolean;
  showHeader?: boolean;
}

const {
  title,
  backHref = "/admin",
  backLabel = "All links",
  lede,
  fullWidth = true,
  showHeader = true
} = Astro.props;
---

<AppLayout title={title} fullWidth={fullWidth}>
  <main class="link-editor shell">
    <slot name="top" />

    {showHeader && (
      <header class="link-editor__header">
        <div>
          {backHref && (
            <a class="back" href={backHref}>
              <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4l-6 6 6 6" /></svg>
              {backLabel}
            </a>
          )}
          <h1>{title}</h1>
          {lede && <p class="lede">{lede}</p>}
        </div>
        <slot name="header-actions" />
      </header>
    )}

    <div class="link-editor__split">
      <div class="link-editor__form">
        <slot />
      </div>

      <aside class="link-editor__preview" aria-label="Live preview">
        <div class="preview-chrome">
          <span class="preview-label">Live preview</span>
          <span class="preview-hint muted">Updates as you edit</span>
        </div>
        <div class="preview-frame-wrap">
          <iframe
            id="linkPreviewFrame"
            title="Fan smartlink preview"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin"
          ></iframe>
        </div>
      </aside>
    </div>
  </main>

  <slot name="scripts" />
</AppLayout>

<style>
  .link-editor {
    display: grid;
    gap: 0.85rem;
    padding-block: 1.1rem 2rem;
    min-height: calc(100dvh - 3.5rem);
  }

  .link-editor__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .link-editor__header h1 {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 720;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .lede {
    margin: 0.35rem 0 0;
    max-width: 42ch;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back:hover {
    color: var(--foreground);
  }

  .link-editor__split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 26rem);
    gap: 1rem;
    align-items: start;
    min-height: 0;
    flex: 1;
  }

  .link-editor__form {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
    max-height: calc(100dvh - 7.5rem);
    overflow: auto;
    padding-right: 0.15rem;
    scrollbar-gutter: stable;
  }

  .link-editor__preview {
    position: sticky;
    top: 0.85rem;
    display: grid;
    gap: 0.55rem;
    min-width: 0;
    max-height: calc(100dvh - 2.5rem);
  }

  .preview-chrome {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding-inline: 0.1rem;
  }

  .preview-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .preview-hint {
    font-size: var(--text-xs);
  }

  .preview-frame-wrap {
    position: relative;
    min-height: 28rem;
    height: calc(100dvh - 6.5rem);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: oklch(0.1 0.008 265);
    overflow: hidden;
    box-shadow: inset 0 1px 0 oklch(1 0 0 / 0.04);
  }

  #linkPreviewFrame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
  }

  @media (max-width: 980px) {
    .link-editor__split {
      grid-template-columns: 1fr;
    }

    .link-editor__form {
      max-height: none;
      overflow: visible;
      padding-right: 0;
    }

    .link-editor__preview {
      position: static;
      max-height: none;
      order: 2;
    }

    .preview-frame-wrap {
      height: min(36rem, 72vh);
      min-height: 22rem;
    }
  }
</style>
