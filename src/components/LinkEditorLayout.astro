---
import AppLayout from "@layouts/AppLayout.astro";

interface Props {
  title: string;
  backHref?: string;
  backLabel?: string;
  lede?: string;
  fullWidth?: boolean;
  showHeader?: boolean;
}

const {
  title,
  backHref = "/admin",
  backLabel = "All links",
  lede,
  fullWidth = true,
  showHeader = true
} = Astro.props;
---

<AppLayout title={title} fullWidth={fullWidth} bodyClass="link-editor-page">
  <main class="link-editor">
    <div class="link-editor__split">
      <div class="link-editor__form">
        <div class="link-editor__form-inner">
          <slot name="top" />

          {showHeader && (
            <header class="link-editor__header">
              <div>
                {backHref && (
                  <a class="back" href={backHref}>
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4l-6 6 6 6" /></svg>
                    {backLabel}
                  </a>
                )}
                <h1>{title}</h1>
                {lede && <p class="lede">{lede}</p>}
              </div>
              <slot name="header-actions" />
            </header>
          )}

          <slot />
        </div>
      </div>

      <aside class="link-editor__preview" aria-label="Live preview">
        <div class="preview-chrome">
          <span class="preview-label">Live preview</span>
          <span class="preview-hint muted">Updates as you edit</span>
        </div>
        <div class="preview-frame-wrap">
          <iframe
            id="linkPreviewFrame"
            title="Fan smartlink preview"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin"
          ></iframe>
        </div>
      </aside>
    </div>
  </main>

  <slot name="scripts" />
</AppLayout>

<style is:global>
  body.link-editor-page .beamlink-admin {
    width: 100%;
    max-width: none;
  }
</style>

<style>
  .link-editor {
    width: 100%;
    min-height: 100dvh;
    margin: 0;
    padding: 0;
  }

  .link-editor__split {
    display: grid;
    grid-template-columns: 50% 50%;
    width: 100%;
    min-height: 100dvh;
    height: 100dvh;
  }

  .link-editor__form {
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    border-right: 1px solid var(--border-strong);
    background: var(--background);
  }

  .link-editor__form-inner {
    display: grid;
    gap: 0.75rem;
    align-content: start;
    height: 100%;
    overflow-y: auto;
    padding: 1rem clamp(1rem, 2.5vw, 2rem) 2rem;
    scrollbar-gutter: stable;
  }

  .link-editor__form-inner :global(.form-block) {
    grid-template-columns: minmax(0, 9.5rem) minmax(0, 1fr);
    gap: 0.45rem 1.25rem;
    padding-block: 1rem;
  }

  .link-editor__form-inner :global(.form-block .block-copy) {
    max-width: none;
  }

  .link-editor__form-inner :global(.style-grid) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .link-editor__form-inner :global(.style-grid--buttons) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .link-editor__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .link-editor__header h1 {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 720;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .lede {
    margin: 0.35rem 0 0;
    max-width: 42ch;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back:hover {
    color: var(--foreground);
  }

  .link-editor__preview {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 0.55rem;
    min-width: 0;
    min-height: 0;
    height: 100%;
    padding: 1rem clamp(0.75rem, 1.5vw, 1.25rem) 1rem clamp(0.5rem, 1vw, 1rem);
    background: oklch(0.11 0.008 265);
  }

  .preview-chrome {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding-inline: 0.15rem;
  }

  .preview-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .preview-hint {
    font-size: var(--text-xs);
  }

  .preview-frame-wrap {
    position: relative;
    min-height: 0;
    height: 100%;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--background);
    overflow: hidden;
  }

  #linkPreviewFrame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
  }

  @media (max-width: 1100px) {
    .link-editor__form-inner :global(.style-grid),
    .link-editor__form-inner :global(.style-grid--buttons) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .link-editor__split {
      grid-template-columns: 1fr;
      grid-template-rows: auto minmax(24rem, 50vh);
      height: auto;
      min-height: 100dvh;
    }

    .link-editor__form {
      border-right: 0;
      border-bottom: 1px solid var(--border-strong);
      max-height: none;
    }

    .link-editor__form-inner {
      height: auto;
      overflow: visible;
    }

    .link-editor__preview {
      height: min(50vh, 36rem);
      min-height: 24rem;
    }
  }

  @media (max-width: 720px) {
    .link-editor__form-inner :global(.form-block) {
      grid-template-columns: 1fr;
    }

    .link-editor__form-inner :global(.style-grid),
    .link-editor__form-inner :global(.style-grid--buttons) {
      grid-template-columns: 1fr;
    }
  }
</style>
