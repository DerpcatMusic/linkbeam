---
import PlatformIcon from "@components/PlatformIcon.astro";
import { formatShortDate } from "@lib/datetime";
import { parseTrackPalette, paletteStyleAttribute } from "@lib/palette";
import {
  asciiPatternDataUri,
  backgroundClasses,
  buttonClasses,
  platformBrandStyle,
  platformIconTint,
  type ButtonStyle,
  type PageBackgroundStyle
} from "@lib/page-style";
import type { LinkMode, Platform } from "@lib/types";

export interface SmartlinkDestinationRow {
  platform: Platform;
  cta: string;
  href: string;
  trackAttrs?: Record<string, string>;
}

interface Props {
  title: string;
  artistName: string;
  isrc?: string | null;
  artworkUrl: string;
  paletteJson?: string | null;
  releaseAt?: string | null;
  effectiveMode: LinkMode;
  pageBackgroundStyle: PageBackgroundStyle;
  buttonStyle: ButtonStyle;
  destinations: SmartlinkDestinationRow[];
  embedded?: boolean;
  previewPane?: boolean;
  showDraftRibbon?: boolean;
  interactive?: boolean;
}

const {
  title,
  artistName,
  isrc = null,
  artworkUrl,
  paletteJson = null,
  releaseAt = null,
  effectiveMode,
  pageBackgroundStyle,
  buttonStyle,
  destinations,
  embedded = false,
  previewPane = false,
  showDraftRibbon = false,
  interactive = true
} = Astro.props;

const isPresave = effectiveMode === "presave";
const paletteVars = parseTrackPalette(paletteJson);
const iconTint = platformIconTint(buttonStyle);
const safeArtwork = artworkUrl.replace(/["\\\n\r]/g, "");
const asciiPattern = pageBackgroundStyle === "ascii" ? asciiPatternDataUri(paletteVars) : "";
const pageStyle = `${paletteStyleAttribute(paletteVars)}; --artwork-image: url("${safeArtwork}")${asciiPattern ? `; --ascii-pattern: ${asciiPattern}` : ""}`;
const countdownFallback = releaseAt
  ? `Releases ${formatShortDate(releaseAt)}`
  : "Release date coming soon";
---

{showDraftRibbon && (
  <div class="draft-ribbon" role="status">
    Draft preview
  </div>
)}

<main
  class:list={[
    "smart-page",
    backgroundClasses(pageBackgroundStyle),
    buttonClasses(buttonStyle),
    embedded && "smart-page--embedded",
    previewPane && "smart-page--preview-pane"
  ]}
  style={pageStyle}
>
  <div class="page-backdrop" aria-hidden="true">
    <div class="artwork-bg"></div>
    {pageBackgroundStyle === "ascii" && <div class="ascii-overlay"></div>}
    {(pageBackgroundStyle === "mesh" || pageBackgroundStyle === "aurora" || pageBackgroundStyle === "vinyl") && (
      <div class:list={["bg-effect", `bg-effect--${pageBackgroundStyle}`]}></div>
    )}
  </div>
  <div class="page-scrim" aria-hidden="true"></div>

  <section class="release">
    <img
      class="artwork"
      src={artworkUrl}
      alt={`${title} cover art`}
      width="640"
      height="640"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="copy">
      <p class="mode">{isPresave ? "Pre-save" : "Listen now"}</p>
      <h1>{title}</h1>
      <p class="artist">{artistName}</p>
      {isrc && <p class="isrc">ISRC {isrc}</p>}
      {isPresave && (
        <p class="countdown" data-release-at={releaseAt ?? ""} aria-live="polite">
          {countdownFallback}
        </p>
      )}
    </div>
  </section>

  {isPresave && interactive && (
    <form class="subscribe" id="subscribeForm">
      <label for="email">Email for release day reminder</label>
      <div class="subscribe-row">
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          inputmode="email"
        />
        <button class="button subscribe-submit" type="submit">Notify me</button>
      </div>
      <p class="subscribe-status muted" id="subscribeStatus" role="status" aria-live="polite"></p>
    </form>
  )}

  <nav class={`destinations count-${destinations.length}`} aria-label="Streaming platforms">
    {destinations.map((row) => (
      <a
        class:list={[
          "destination",
          row.platform === "spotify" && "destination--spotify"
        ]}
        href={row.href}
        data-platform={row.platform}
        style={platformBrandStyle(row.platform)}
        tabindex={interactive ? undefined : -1}
        aria-disabled={interactive ? undefined : "true"}
        {...row.trackAttrs}
      >
        <PlatformIcon platform={row.platform} size={22} tint={iconTint} />
        <span>{row.cta}</span>
        <svg class="chevron" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 4l6 6-6 6" /></svg>
      </a>
    ))}
  </nav>
</main>

{isPresave && releaseAt && interactive && (
  <script is:inline define:vars={{ releaseAt }}>
    const countdown = document.querySelector(".countdown");
    const target = new Date(releaseAt).getTime();
    if (!Number.isNaN(target)) {
      function tick() {
        const diff = Math.max(0, target - Date.now());
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);
        if (countdown) {
          countdown.textContent = diff <= 0
            ? "Out now"
            : `Releases in ${days}d ${hours}h ${minutes}m ${seconds}s`;
        }
      }
      tick();
      setInterval(tick, 1000);
    }
  </script>
)}

{!interactive && (
  <script is:inline>
    document.querySelectorAll("a.destination").forEach((anchor) => {
      anchor.addEventListener("click", (event) => event.preventDefault());
    });
  </script>
)}

<style>
  .draft-ribbon {
    position: fixed;
    top: 0.75rem;
    left: 50%;
    z-index: 30;
    translate: -50% 0;
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    background: var(--warn, oklch(0.78 0.15 70));
    color: oklch(0.18 0.02 70);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 6px 18px oklch(0 0 0 / 0.28);
  }

  .smart-page {
    position: relative;
    width: min(30rem, calc(100% - 2rem));
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    margin-inline: auto;
    padding-block: 1.75rem;
    isolation: isolate;
  }

  :global(.beamlink-link--embedded) {
    min-height: 0;
    overflow: hidden;
    background: var(--background);
  }

  :global(.beamlink-link--preview-pane) {
    min-height: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--background);
  }

  .smart-page--embedded {
    width: min(100% - 1.5rem, 24rem);
    min-height: 0;
    justify-content: start;
    gap: 0.8rem;
    padding-block: 1.25rem;
  }

  .smart-page--preview-pane {
    width: 100%;
    max-width: none;
    min-height: 100%;
    justify-content: start;
    gap: 0.85rem;
    margin-inline: 0;
    padding: clamp(1rem, 4vw, 1.75rem) clamp(1rem, 5vw, 2rem) 2rem;
    box-sizing: border-box;
  }

  .smart-page--preview-pane .page-backdrop {
    position: absolute;
    inset: -5rem -4rem;
  }

  .page-backdrop {
    position: fixed;
    inset: -7rem;
    z-index: -2;
    overflow: hidden;
    pointer-events: none;
  }

  .smart-page--embedded .page-backdrop {
    position: absolute;
    inset: -4rem -3rem;
  }

  .artwork-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, oklch(0.1 0.01 260 / 0.16), var(--page-tint, var(--background)) 86%),
      var(--artwork-image);
    background-position: center;
    background-size: cover;
    opacity: 0;
    transform: scale(1.12);
  }

  .smart-page--bg-blur .artwork-bg,
  .smart-page--bg-ascii .artwork-bg {
    opacity: 0.95;
    filter: blur(3.8rem) saturate(1.38) brightness(1.22);
  }

  .smart-page--embedded.smart-page--bg-blur .artwork-bg,
  .smart-page--embedded.smart-page--bg-ascii .artwork-bg {
    filter: blur(3rem) saturate(1.28) brightness(1.14);
    transform: scale(1);
  }

  .smart-page--bg-ascii .artwork-bg {
    filter: blur(2.2rem) saturate(1.2) brightness(1.08) contrast(1.12);
    image-rendering: pixelated;
  }

  .ascii-overlay {
    position: absolute;
    inset: 0;
    background-image: var(--ascii-pattern);
    background-size: 260px 200px;
    mix-blend-mode: soft-light;
    opacity: 0.72;
  }

  .bg-effect {
    position: absolute;
    inset: 0;
  }

  .bg-effect--mesh {
    background:
      radial-gradient(ellipse 90% 70% at 12% 18%, color-mix(in oklch, var(--page-tint) 88%, var(--primary) 12%) 0%, transparent 58%),
      radial-gradient(ellipse 75% 60% at 88% 14%, color-mix(in oklch, var(--primary) 72%, var(--page-tint) 28%) 0%, transparent 52%),
      radial-gradient(ellipse 80% 65% at 72% 88%, color-mix(in oklch, var(--page-tint) 65%, var(--surface) 35%) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 42% 58%, color-mix(in oklch, var(--primary) 45%, transparent) 0%, transparent 62%),
      var(--background);
  }

  .bg-effect--aurora::before,
  .bg-effect--aurora::after {
    content: "";
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    filter: blur(4.5rem);
    opacity: 0.72;
  }

  .bg-effect--aurora::before {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 70%, transparent) 0%, transparent 68%);
    transform: translate(-8%, -6%);
  }

  .bg-effect--aurora::after {
    background: radial-gradient(circle, color-mix(in oklch, var(--page-tint) 75%, var(--primary) 25%) 0%, transparent 70%);
    transform: translate(10%, 8%);
  }

  .bg-effect--aurora {
    background: linear-gradient(165deg, var(--background), color-mix(in oklch, var(--page-tint) 55%, var(--background)));
  }

  .bg-effect--vinyl {
    background:
      repeating-radial-gradient(
        circle at 50% 42%,
        transparent 0 2px,
        color-mix(in oklch, var(--foreground) 8%, transparent) 2px 3px
      ),
      radial-gradient(circle at 50% 42%, color-mix(in oklch, var(--page-tint) 70%, var(--primary) 30%) 0%, transparent 38%),
      radial-gradient(circle at 50% 42%, color-mix(in oklch, var(--page-tint) 45%, var(--background)) 0%, var(--background) 72%);
  }

  @media (prefers-reduced-motion: no-preference) {
    .bg-effect--aurora::before {
      animation: aurora-drift-a 22s ease-in-out infinite alternate;
    }

    .bg-effect--aurora::after {
      animation: aurora-drift-b 28s ease-in-out infinite alternate;
    }
  }

  @keyframes aurora-drift-a {
    from { transform: translate(-12%, -8%) scale(1); }
    to { transform: translate(6%, 4%) scale(1.08); }
  }

  @keyframes aurora-drift-b {
    from { transform: translate(8%, 6%) scale(1.02); }
    to { transform: translate(-6%, -4%) scale(0.96); }
  }

  .page-scrim {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(180deg, oklch(0.02 0.006 260 / 0.28), oklch(0.02 0.006 260 / 0.6)),
      oklch(0.06 0.01 260 / calc(var(--scrim-opacity, 0.72) * 0.62));
  }

  .smart-page--embedded .page-scrim {
    position: absolute;
    inset: -1.5rem;
  }

  .release {
    display: grid;
    justify-items: center;
    gap: 1rem;
    text-align: center;
  }

  .artwork {
    width: min(74vw, 18rem);
    height: min(74vw, 18rem);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 16px;
    background: var(--surface);
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.12) inset,
      0 0 0 1px oklch(0 0 0 / 0.35),
      0 24px 60px -18px oklch(0 0 0 / 0.7);
  }

  .smart-page--embedded .artwork {
    width: min(58vw, 13rem);
    height: min(58vw, 13rem);
    border-radius: 14px;
  }

  .copy {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
    max-width: 22rem;
  }

  .mode,
  .isrc,
  .artist,
  .countdown {
    margin: 0;
  }

  .mode {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  h1 {
    margin: 0;
    max-width: 15ch;
    font-size: clamp(1.65rem, 5.4vw, 2.35rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .smart-page--embedded h1 {
    font-size: clamp(1.45rem, 8vw, 1.9rem);
  }

  .artist {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .isrc,
  .countdown {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .subscribe {
    display: grid;
    gap: 0.55rem;
    width: 100%;
  }

  .subscribe label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .subscribe-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
  }

  .subscribe-row input {
    min-width: 0;
    min-height: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.65rem 0.75rem;
    background: var(--surface);
    color: var(--foreground);
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .subscribe-row input::placeholder {
    color: var(--muted);
    opacity: 1;
  }

  .subscribe-submit {
    border-radius: 12px;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .subscribe-submit:hover {
    filter: brightness(1.04);
  }

  .subscribe-status {
    margin: 0;
    min-height: 1.2rem;
    font-size: 0.8rem;
  }

  .destinations {
    display: grid;
    gap: 0.55rem;
    width: 100%;
    margin-top: 0.15rem;
  }

  .destination {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.8rem;
    min-height: 3.5rem;
    padding: 0.72rem 0.95rem 0.72rem 0.9rem;
    border-radius: 14px;
    border: 1px solid oklch(0.98 0.004 265 / 0.14);
    background: oklch(0.22 0.006 265 / 0.55);
    color: var(--foreground);
    font-size: 0.95rem;
    font-weight: 600;
    backdrop-filter: blur(14px) saturate(1.1);
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .smart-page--embedded .destination {
    min-height: 3.2rem;
    padding-block: 0.62rem;
    border-radius: 12px;
    font-size: 0.9rem;
  }

  .destination > span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .destination .chevron {
    flex-shrink: 0;
    color: oklch(0.98 0.004 265 / 0.5);
    transition: transform 180ms ease, color 180ms ease;
  }

  .destination:hover {
    transform: translateY(-1px);
    background: oklch(0.29 0.006 265 / 0.7);
    border-color: oklch(0.98 0.004 265 / 0.28);
  }

  .destination:hover .chevron {
    transform: translateX(2px);
    color: var(--foreground);
  }

  .smart-page--btn-monochrome .destination:first-child,
  .smart-page--btn-logo-color .destination:first-child,
  .smart-page--btn-colored-border .destination:first-child,
  .smart-page--btn-gradient-lr .destination:first-child,
  .smart-page--btn-gradient-logo .destination:first-child {
    background: oklch(0.97 0.005 265);
    border-color: transparent;
    color: oklch(0.17 0.006 265);
    box-shadow: 0 8px 24px -12px oklch(0 0 0 / 0.6);
  }

  .smart-page--btn-monochrome .destination:first-child .chevron,
  .smart-page--btn-logo-color .destination:first-child .chevron,
  .smart-page--btn-colored-border .destination:first-child .chevron,
  .smart-page--btn-gradient-lr .destination:first-child .chevron,
  .smart-page--btn-gradient-logo .destination:first-child .chevron {
    color: oklch(0.17 0.006 265 / 0.55);
  }

  .smart-page--btn-monochrome .destination:first-child:hover,
  .smart-page--btn-logo-color .destination:first-child:hover,
  .smart-page--btn-colored-border .destination:first-child:hover,
  .smart-page--btn-gradient-lr .destination:first-child:hover,
  .smart-page--btn-gradient-logo .destination:first-child:hover {
    background: oklch(1 0 0);
  }

  .smart-page--btn-monochrome .destination:first-child:hover .chevron,
  .smart-page--btn-logo-color .destination:first-child:hover .chevron,
  .smart-page--btn-colored-border .destination:first-child:hover .chevron,
  .smart-page--btn-gradient-lr .destination:first-child:hover .chevron,
  .smart-page--btn-gradient-logo .destination:first-child:hover .chevron {
    color: oklch(0.17 0.006 265);
  }

  .smart-page--btn-monochrome .destination:first-child:focus-visible,
  .smart-page--btn-logo-color .destination:first-child:focus-visible,
  .smart-page--btn-colored-border .destination:first-child:focus-visible,
  .smart-page--btn-gradient-lr .destination:first-child:focus-visible,
  .smart-page--btn-gradient-logo .destination:first-child:focus-visible {
    outline-color: oklch(0.17 0.006 265);
  }

  .destinations.count-1 .destination {
    min-height: 3.75rem;
    font-size: 1rem;
  }

  .destination:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 2px;
  }

  .smart-page--btn-logo-color .destination :global(.platform-icon) {
    color: var(--platform-brand);
  }

  .smart-page--btn-colored-border .destination {
    border-color: color-mix(in srgb, var(--platform-brand) 48%, oklch(0.98 0.004 265 / 0.14));
  }

  .smart-page--btn-gradient-lr .destination {
    background: linear-gradient(
      90deg,
      oklch(0.22 0.006 265 / 0.55) 0%,
      color-mix(in srgb, var(--platform-brand) 32%, oklch(0.22 0.006 265 / 0.55)) 100%
    );
  }

  .smart-page--btn-gradient-logo .destination {
    background: linear-gradient(
      90deg,
      oklch(0.22 0.006 265 / 0.55) 0%,
      color-mix(in srgb, var(--platform-brand) 38%, oklch(0.22 0.006 265 / 0.55)) 100%
    );
  }

  .smart-page--btn-gradient-logo .destination :global(.platform-icon) {
    color: var(--platform-brand);
  }

  .smart-page--btn-full-color .destination {
    background: var(--platform-brand);
    border-color: color-mix(in srgb, var(--platform-brand) 80%, oklch(0 0 0));
    color: var(--platform-ink);
    backdrop-filter: none;
  }

  .smart-page--btn-full-color .destination :global(.platform-icon) {
    color: var(--platform-ink);
  }

  .smart-page--btn-full-color .destination .chevron {
    color: color-mix(in srgb, var(--platform-ink) 55%, transparent);
  }

  .smart-page--btn-full-color .destination:hover {
    background: color-mix(in srgb, var(--platform-brand) 92%, white);
    border-color: color-mix(in srgb, var(--platform-brand) 80%, oklch(0 0 0));
  }

  .smart-page--btn-full-color .destination:hover .chevron {
    color: var(--platform-ink);
  }

  .smart-page--btn-full-color .destination--spotify,
  .smart-page--btn-full-color .destination:first-child {
    background: var(--platform-brand);
    color: var(--platform-ink);
    box-shadow: 0 8px 24px -12px color-mix(in srgb, var(--platform-brand) 55%, oklch(0 0 0));
  }

  .smart-page--btn-logo-color .destination:first-child :global(.platform-icon) {
    color: var(--platform-brand);
  }

  .subscribe-row input:focus-visible {
    outline: 2px solid var(--foreground);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .release,
    .subscribe,
    .destinations {
      animation: rise 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .release {
      animation-delay: 40ms;
    }

    .subscribe {
      animation-delay: 130ms;
    }

    .destinations {
      animation-delay: 200ms;
    }

    .artwork {
      animation: artwork-in 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }

  @keyframes artwork-in {
    from {
      opacity: 0;
      transform: scale(0.94);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-effect--aurora::before,
    .bg-effect--aurora::after {
      animation: none;
    }

    .destination:hover,
    .subscribe-submit:hover {
      transform: none;
    }

    .destination:hover .chevron {
      transform: none;
    }
  }
</style>
