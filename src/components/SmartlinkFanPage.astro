---
import PlatformIcon from "@components/PlatformIcon.astro";
import { formatShortDate } from "@lib/datetime";
import { parseTrackPalette, paletteStyleAttribute } from "@lib/palette";
import {
  asciiPatternDataUri,
  backgroundClasses,
  buttonClasses,
  platformBrandStyle,
  platformIconTint,
  type ButtonStyle,
  type PageBackgroundStyle
} from "@lib/page-style";
import {
  DEFAULT_PAGE_STYLE_OPTIONS,
  normalizePageStyleOptions,
  styleOptionsCssVars,
  type PageStyleOptions
} from "@lib/page-style-options";
import type { LinkMode, Platform } from "@lib/types";

export interface SmartlinkDestinationRow {
  platform: Platform;
  cta: string;
  href: string;
  trackAttrs?: Record<string, string>;
}

interface Props {
  title: string;
  artistName: string;
  isrc?: string | null;
  artworkUrl: string;
  paletteJson?: string | null;
  releaseAt?: string | null;
  effectiveMode: LinkMode;
  pageBackgroundStyle: PageBackgroundStyle;
  buttonStyle: ButtonStyle;
  pageStyleOptions?: PageStyleOptions | null;
  destinations: SmartlinkDestinationRow[];
  embedded?: boolean;
  previewPane?: boolean;
  showDraftRibbon?: boolean;
  interactive?: boolean;
}

const {
  title,
  artistName,
  isrc = null,
  artworkUrl,
  paletteJson = null,
  releaseAt = null,
  effectiveMode,
  pageBackgroundStyle,
  buttonStyle,
  pageStyleOptions = null,
  destinations,
  embedded = false,
  previewPane = false,
  showDraftRibbon = false,
  interactive = true
} = Astro.props;

const isPresave = effectiveMode === "presave";
const paletteVars = parseTrackPalette(paletteJson);
const styleOptions = normalizePageStyleOptions(pageStyleOptions ?? DEFAULT_PAGE_STYLE_OPTIONS);
const iconTint = platformIconTint(buttonStyle);
const safeArtwork = artworkUrl.replace(/["\\\n\r]/g, "");
const asciiOpts = styleOptions.ascii;
const asciiPattern =
  pageBackgroundStyle === "ascii"
    ? asciiPatternDataUri(paletteVars, asciiOpts.density, asciiOpts.contrast)
    : "";
const fxVars = styleOptionsCssVars(pageBackgroundStyle, styleOptions);
const pageStyle = [
  paletteStyleAttribute(paletteVars),
  `--artwork-image: url("${safeArtwork}")`,
  fxVars,
  asciiPattern ? `--ascii-pattern: ${asciiPattern}` : ""
]
  .filter(Boolean)
  .join("; ");
const countdownFallback = releaseAt
  ? `Releases ${formatShortDate(releaseAt)}`
  : "Release date coming soon";
const asciiEnhance = pageBackgroundStyle === "ascii";
---

{showDraftRibbon && (
  <div class="draft-ribbon" role="status">
    Draft preview
  </div>
)}

<main
  class:list={[
    "smart-page",
    backgroundClasses(pageBackgroundStyle),
    buttonClasses(buttonStyle),
    embedded && "smart-page--embedded",
    previewPane && "smart-page--preview-pane"
  ]}
  style={pageStyle}
>
  <div class="page-backdrop" aria-hidden="true">
    <div class="artwork-bg"></div>
    {pageBackgroundStyle === "ascii" && (
      <div class="ascii-layer" data-ascii-root data-ascii-motion={asciiOpts.motion} data-ascii-density={asciiOpts.density} data-ascii-contrast={String(asciiOpts.contrast)}>
        <div class="ascii-overlay" data-ascii-fallback></div>
        <canvas class="ascii-canvas" data-ascii-canvas hidden></canvas>
      </div>
    )}
    {pageBackgroundStyle === "mesh" && (
      <div class="bg-effect bg-effect--mesh">
        <div class="mesh-base"></div>
        <div class="mesh-orbs">
          <span class="mesh-orb mesh-orb--1"></span>
          <span class="mesh-orb mesh-orb--2"></span>
          <span class="mesh-orb mesh-orb--3"></span>
          <span class="mesh-orb mesh-orb--4"></span>
          <span class="mesh-orb mesh-orb--5"></span>
          <span class="mesh-orb mesh-orb--6"></span>
        </div>
      </div>
    )}
    {pageBackgroundStyle === "aurora" && (
      <div class="bg-effect bg-effect--aurora">
        <span class="aurora-veil"></span>
        <span class="aurora-sheet aurora-sheet--a"></span>
        <span class="aurora-sheet aurora-sheet--b"></span>
        <span class="aurora-sheet aurora-sheet--c"></span>
        <span class="aurora-sheet aurora-sheet--d"></span>
        <span class="aurora-spark"></span>
      </div>
    )}
    {pageBackgroundStyle === "vinyl" && (
      <div class="bg-effect bg-effect--vinyl">
        <div class="vinyl-disc">
          <div class="vinyl-grooves"></div>
          <div class="vinyl-shine"></div>
          <div class="vinyl-label"></div>
        </div>
      </div>
    )}
  </div>
  <div class="page-scrim" aria-hidden="true"></div>

  <section class="release">
    <img
      class="artwork"
      src={artworkUrl}
      alt={`${title} cover art`}
      width="640"
      height="640"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="copy">
      <p class="mode">{isPresave ? "Pre-save" : "Listen now"}</p>
      <h1>{title}</h1>
      <p class="artist">{artistName}</p>
      {isrc && <p class="isrc">ISRC {isrc}</p>}
      {isPresave && (
        <p class="countdown" data-release-at={releaseAt ?? ""} aria-live="polite">
          {countdownFallback}
        </p>
      )}
    </div>
  </section>

  {isPresave && interactive && (
    <form class="subscribe" id="subscribeForm">
      <label for="email">Email for release day reminder</label>
      <label class="honeypot" aria-hidden="true">Website <input id="website" name="website" tabindex="-1" autocomplete="off" /></label>
      <div class="subscribe-row">
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          inputmode="email"
        />
        <button class="button subscribe-submit" type="submit">Notify me</button>
      </div>
      <p class="subscribe-status muted" id="subscribeStatus" role="status" aria-live="polite"></p>
      <p class="subscribe-disclosure muted">Your email is shared with this link's owner for release updates.</p>
    </form>
  )}

  <nav class={`destinations count-${destinations.length}`} aria-label="Streaming platforms">
    {destinations.map((row) => (
      <a
        class:list={[
          "destination",
          row.platform === "spotify" && "destination--spotify"
        ]}
        href={row.href}
        data-platform={row.platform}
        style={platformBrandStyle(row.platform)}
        tabindex={interactive ? undefined : -1}
        aria-disabled={interactive ? undefined : "true"}
        {...row.trackAttrs}
      >
        <PlatformIcon platform={row.platform} size={22} tint={iconTint} />
        <span>{row.cta}</span>
        <svg class="chevron" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 4l6 6-6 6" /></svg>
      </a>
    ))}
  </nav>
</main>

{isPresave && releaseAt && interactive && (
  <script is:inline define:vars={{ releaseAt }}>
    const countdown = document.querySelector(".countdown");
    const target = new Date(releaseAt).getTime();
    if (!Number.isNaN(target)) {
      function tick() {
        const diff = Math.max(0, target - Date.now());
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);
        if (countdown) {
          countdown.textContent = diff <= 0
            ? "Out now"
            : `Releases in ${days}d ${hours}h ${minutes}m ${seconds}s`;
        }
      }
      tick();
      setInterval(tick, 1000);
    }
  </script>
)}

{!interactive && (
  <script is:inline>
    document.querySelectorAll("a.destination").forEach((anchor) => {
      anchor.addEventListener("click", (event) => event.preventDefault());
    });
  </script>
)}

{asciiEnhance && (
  <script is:inline>
    (function initAsciiMosaic() {
      const root = document.querySelector("[data-ascii-root]");
      const canvas = root?.querySelector("[data-ascii-canvas]");
      const fallback = root?.querySelector("[data-ascii-fallback]");
      const artwork = document.querySelector(".artwork");
      if (!root || !canvas || !(canvas instanceof HTMLCanvasElement) || !(artwork instanceof HTMLImageElement)) return;

      const CHARSET = " .:-=+*#%@";
      const density = root.getAttribute("data-ascii-density") || "md";
      const contrast = Number(root.getAttribute("data-ascii-contrast") || "0.7");
      let motion = root.getAttribute("data-ascii-motion") || "live";
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) motion = "static";

      const grid =
        density === "sm" ? { cols: 48, rows: 28 } :
        density === "lg" ? { cols: 96, rows: 56 } :
        { cols: 72, rows: 42 };

      const ctx = canvas.getContext("2d", { alpha: true });
      if (!ctx) return;

      const sample = document.createElement("canvas");
      const sampleCtx = sample.getContext("2d", { willReadFrequently: true });
      if (!sampleCtx) return;

      let raf = 0;
      let started = false;

      function clamp01(n) {
        return Math.min(1, Math.max(0, n));
      }

      function charFor(luma) {
        const mid = 0.5;
        const adjusted = clamp01(mid + (luma - mid) * (0.55 + contrast * 0.75));
        const inverted = 1 - adjusted;
        return CHARSET[Math.min(CHARSET.length - 1, Math.floor(inverted * CHARSET.length))] || " ";
      }

      function samplePixels() {
        sample.width = grid.cols;
        sample.height = grid.rows;
        sampleCtx.clearRect(0, 0, grid.cols, grid.rows);
        try {
          sampleCtx.drawImage(artwork, 0, 0, grid.cols, grid.rows);
          return sampleCtx.getImageData(0, 0, grid.cols, grid.rows);
        } catch {
          return null;
        }
      }

      function paint(imageData, t) {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const cssW = root.clientWidth || window.innerWidth;
        const cssH = root.clientHeight || window.innerHeight;
        canvas.width = Math.max(1, Math.floor(cssW * dpr));
        canvas.height = Math.max(1, Math.floor(cssH * dpr));
        canvas.style.width = cssW + "px";
        canvas.style.height = cssH + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, cssW, cssH);
        ctx.fillStyle = "oklch(0.08 0.01 265 / 0.42)";
        ctx.fillRect(0, 0, cssW, cssH);

        const cellW = cssW / grid.cols;
        const cellH = cssH / grid.rows;
        const fontSize = Math.max(7, Math.min(cellW, cellH) * 0.92);
        ctx.font = "700 " + fontSize + "px ui-monospace, SFMono-Regular, Menlo, monospace";
        ctx.textBaseline = "middle";
        ctx.textAlign = "center";

        const data = imageData.data;
        const animate = motion === "live";
        for (let y = 0; y < grid.rows; y += 1) {
          for (let x = 0; x < grid.cols; x += 1) {
            const i = (y * grid.cols + x) * 4;
            const r = data[i];
            const g = data[i + 1];
            const b = data[i + 2];
            let luma = (0.2126 * r + 0.7152 * g + 0.0722 * b) / 255;
            if (animate) {
              const wave = Math.sin((x * 0.35) + (y * 0.22) + t * 1.6) * 0.045
                + Math.cos((x * 0.18) - (y * 0.31) + t * 1.1) * 0.03;
              luma = clamp01(luma + wave);
            }
            const ch = charFor(luma);
            if (ch === " ") continue;
            const boost = 1 + (contrast - 0.7) * 0.35;
            const rr = Math.min(255, Math.round(r * boost));
            const gg = Math.min(255, Math.round(g * boost));
            const bb = Math.min(255, Math.round(b * boost));
            ctx.fillStyle = "rgb(" + rr + " " + gg + " " + bb + ")";
            ctx.globalAlpha = 0.78 + luma * 0.2;
            ctx.fillText(ch, (x + 0.5) * cellW, (y + 0.5) * cellH);
          }
        }
        ctx.globalAlpha = 1;
      }

      function start() {
        if (started) return;
        const imageData = samplePixels();
        if (!imageData) return;
        started = true;
        canvas.hidden = false;
        if (fallback) fallback.style.opacity = "0";

        // static + shimmer: one artwork sample; shimmer keeps CSS filter on canvas
        paint(imageData, 0);
        if (motion === "shimmer") canvas.classList.add("ascii-canvas--shimmer");
        if (motion !== "live") return;

        const tick = (now) => {
          paint(imageData, now / 1000);
          raf = window.requestAnimationFrame(tick);
        };
        raf = window.requestAnimationFrame(tick);
      }

      if (artwork.complete && artwork.naturalWidth > 0) start();
      else artwork.addEventListener("load", start, { once: true });

      window.addEventListener("pagehide", () => {
        if (raf) window.cancelAnimationFrame(raf);
      }, { once: true });
    })();
  </script>
)}

<style>
  .honeypot { position: absolute !important; width: 1px; height: 1px; overflow: hidden; clip-path: inset(50%); }
  .draft-ribbon {
    position: fixed;
    top: 0.75rem;
    left: 50%;
    z-index: 30;
    translate: -50% 0;
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    background: var(--warn, oklch(0.78 0.15 70));
    color: oklch(0.18 0.02 70);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 6px 18px oklch(0 0 0 / 0.28);
  }

  .smart-page {
    position: relative;
    width: min(30rem, calc(100% - 2rem));
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    margin-inline: auto;
    padding-block: 1.75rem;
    isolation: isolate;
  }

  :global(.beamlink-link--embedded) {
    min-height: 0;
    overflow: hidden;
    background: var(--background);
  }

  :global(.beamlink-link--preview-pane) {
    min-height: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--background);
  }

  .smart-page--embedded {
    width: min(100% - 1.5rem, 24rem);
    min-height: 0;
    justify-content: start;
    gap: 0.8rem;
    padding-block: 1.25rem;
  }

  .smart-page--preview-pane {
    width: 100%;
    max-width: none;
    min-height: 100%;
    justify-content: start;
    gap: clamp(0.75rem, 2.5vw, 1rem);
    margin-inline: 0;
    padding: clamp(0.85rem, 3.5vw, 1.5rem) clamp(0.85rem, 4vw, 1.25rem) 1.25rem;
    box-sizing: border-box;
  }

  .smart-page--preview-pane .page-backdrop {
    position: absolute;
    inset: -18vmin;
  }

  .smart-page--preview-pane .page-scrim {
    position: absolute;
    inset: 0;
  }

  .page-backdrop {
    position: fixed;
    inset: -7rem;
    z-index: -2;
    overflow: hidden;
    pointer-events: none;
  }

  .smart-page--embedded .page-backdrop {
    position: absolute;
    inset: -4rem -3rem;
  }

  .artwork-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, oklch(0.1 0.01 260 / 0.16), var(--page-tint, var(--background)) 86%),
      var(--artwork-image);
    background-position: center;
    background-size: cover;
    opacity: 0;
    transform: scale(1.12);
  }

  .smart-page--bg-blur .artwork-bg {
    opacity: calc(0.82 + (var(--fx-intensity, 1) - 1) * 0.12);
    filter:
      blur(calc(3.2rem * var(--fx-intensity, 1)))
      saturate(calc(1.2 * var(--fx-saturate, 1)))
      brightness(calc(1.12 + (var(--fx-intensity, 1) - 1) * 0.1));
    transform: scale(calc(1.08 + (var(--fx-intensity, 1) - 1) * 0.04));
  }

  .smart-page--bg-mesh .artwork-bg,
  .smart-page--bg-aurora .artwork-bg,
  .smart-page--bg-vinyl .artwork-bg {
    opacity: calc(0.42 + (var(--fx-intensity, 1) - 1) * 0.1);
    filter: blur(2.6rem) saturate(1.42) brightness(1.14);
    transform: scale(1.1);
  }

  .smart-page--bg-vinyl .artwork-bg {
    mask-image: radial-gradient(circle at 50% var(--vinyl-disc-y, 34%), black 0%, black 22%, transparent 36%);
    opacity: calc(0.55 + (var(--fx-intensity, 1) - 1) * 0.12);
  }

  .smart-page--embedded.smart-page--bg-blur .artwork-bg {
    filter:
      blur(calc(2.6rem * var(--fx-intensity, 1)))
      saturate(calc(1.15 * var(--fx-saturate, 1)))
      brightness(1.1);
    transform: scale(1);
  }

  .smart-page--embedded.smart-page--bg-mesh .artwork-bg,
  .smart-page--embedded.smart-page--bg-aurora .artwork-bg,
  .smart-page--embedded.smart-page--bg-vinyl .artwork-bg {
    filter: blur(2.2rem) saturate(1.32) brightness(1.1);
    transform: scale(1.04);
  }

  .smart-page--bg-ascii .artwork-bg {
    opacity: 0.55;
    filter: blur(1.1rem) saturate(1.2) brightness(0.88) contrast(calc(1.15 + var(--ascii-contrast, 0.7) * 0.25));
    image-rendering: pixelated;
  }

  .ascii-layer {
    position: absolute;
    inset: 0;
  }

  .ascii-overlay,
  .ascii-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ascii-overlay {
    background-color: color-mix(in oklch, var(--background) 55%, transparent);
    background-image: var(--ascii-pattern);
    background-size: var(--ascii-tile, 200px 160px);
    mix-blend-mode: normal;
    opacity: 1;
    transition: opacity 320ms ease;
    image-rendering: pixelated;
  }

  .ascii-canvas {
    display: block;
    pointer-events: none;
  }

  .ascii-layer[data-ascii-motion="shimmer"] .ascii-overlay,
  .ascii-canvas--shimmer {
    animation: ascii-shimmer 7.5s ease-in-out infinite alternate;
  }

  @keyframes ascii-shimmer {
    from { filter: brightness(0.92) contrast(1.05); background-position: 0 0; }
    to { filter: brightness(1.08) contrast(1.18); background-position: 12px -8px; }
  }

  .smart-page--bg-mesh .page-scrim,
  .smart-page--bg-aurora .page-scrim,
  .smart-page--bg-vinyl .page-scrim,
  .smart-page--bg-ascii .page-scrim {
    background:
      linear-gradient(180deg, oklch(0.02 0.006 260 / 0.16), oklch(0.02 0.006 260 / 0.34)),
      oklch(0.06 0.01 260 / 0.28);
  }

  .bg-effect {
    position: absolute;
    inset: 0;
    overflow: hidden;
    isolation: isolate;
  }

  /* --- Mesh: Aceternity-style animated orbs --- */
  .bg-effect--mesh {
    --mesh-orb-size: clamp(11rem, 52vmin, 30rem);
    --mesh-duration: calc(26s / var(--fx-speed, 1));
  }

  .mesh-base {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      155deg,
      color-mix(in oklch, var(--background) 45%, var(--page-tint)),
      var(--background) 72%
    );
  }

  .mesh-orbs {
    position: absolute;
    inset: -22%;
    filter: blur(calc(3rem * (0.85 + var(--fx-intensity, 1) * 0.15)));
    opacity: calc(0.75 + var(--fx-intensity, 1) * 0.2);
  }

  .mesh-orb {
    position: absolute;
    width: var(--mesh-orb-size);
    height: var(--mesh-orb-size);
    top: calc(50% - var(--mesh-orb-size) / 2);
    left: calc(50% - var(--mesh-orb-size) / 2);
    border-radius: 50%;
    mix-blend-mode: hard-light;
    opacity: calc(0.72 + var(--fx-intensity, 1) * 0.18);
    will-change: transform;
  }

  .mesh-orb--1 {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 72%, var(--page-tint)) 0%, transparent 58%);
    transform-origin: center;
    animation: mesh-float-y var(--mesh-duration) cubic-bezier(0.25, 1, 0.5, 1) infinite;
  }

  .mesh-orb--2 {
    background: radial-gradient(circle, color-mix(in oklch, var(--page-tint) 82%, var(--primary)) 0%, transparent 56%);
    transform-origin: calc(50% - 14vmin);
    animation: mesh-orbit calc(var(--mesh-duration) * 0.85) cubic-bezier(0.22, 1, 0.36, 1) infinite reverse;
  }

  .mesh-orb--3 {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 58%, transparent) 0%, transparent 62%);
    transform-origin: calc(50% + 12vmin);
    animation: mesh-sway calc(var(--mesh-duration) * 0.95) cubic-bezier(0.25, 1, 0.5, 1) infinite;
  }

  .mesh-orb--4 {
    background: radial-gradient(circle, color-mix(in oklch, var(--page-tint) 68%, var(--surface)) 0%, transparent 60%);
    transform-origin: calc(50% - 8vmin) calc(50% + 10vmin);
    animation: mesh-orbit calc(var(--mesh-duration) * 1.15) cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  .mesh-orb--5 {
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 48%, var(--page-tint)) 0%, transparent 64%);
    transform-origin: calc(50% + 16vmin) calc(50% - 6vmin);
    animation: mesh-float-y calc(var(--mesh-duration) * 0.9) cubic-bezier(0.25, 1, 0.5, 1) infinite reverse;
  }

  .mesh-orb--6 {
    width: calc(var(--mesh-orb-size) * 0.72);
    height: calc(var(--mesh-orb-size) * 0.72);
    background: radial-gradient(circle, color-mix(in oklch, var(--primary) 38%, white) 0%, transparent 60%);
    transform-origin: calc(50% - 18vmin) calc(50% + 4vmin);
    opacity: calc(0.45 + var(--fx-intensity, 1) * 0.2);
    animation: mesh-sway calc(var(--mesh-duration) * 1.2) cubic-bezier(0.22, 1, 0.36, 1) infinite reverse;
  }

  @keyframes mesh-float-y {
    0%, 100% { transform: translateY(-18%) scale(1); }
    50% { transform: translateY(18%) scale(1.08); }
  }

  @keyframes mesh-orbit {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  @keyframes mesh-sway {
    0%, 100% { transform: translate(-16%, -12%) scale(1); }
    50% { transform: translate(16%, 12%) scale(1.07); }
  }

  /* --- Aurora: elliptical drifting sheets --- */
  .bg-effect--aurora {
    --aurora-duration: calc(18s / var(--fx-speed, 1));
    background: linear-gradient(
      168deg,
      color-mix(in oklch, var(--background) 58%, transparent),
      color-mix(in oklch, var(--page-tint) 48%, var(--background))
    );
  }

  .aurora-veil {
    position: absolute;
    inset: -10%;
    background:
      radial-gradient(ellipse 90% 55% at 50% -10%, color-mix(in oklch, var(--primary) 28%, transparent), transparent 70%),
      radial-gradient(ellipse 70% 45% at 80% 90%, color-mix(in oklch, var(--page-tint) 32%, transparent), transparent 65%);
    opacity: calc(0.45 * var(--fx-intensity, 1));
    animation: aurora-veil-breathe calc(var(--aurora-duration) * 1.4) ease-in-out infinite alternate;
  }

  .aurora-sheet {
    position: absolute;
    width: 210%;
    height: 210%;
    top: -55%;
    left: -55%;
    border-radius: 50%;
