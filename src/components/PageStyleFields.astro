---
import {
  BUTTON_STYLES,
  PAGE_BACKGROUND_STYLES,
  STYLE_CARD_PREVIEW_PALETTE,
  asciiPatternDataUri,
  buttonStyleDescriptions,
  buttonStyleLabels,
  pageBackgroundDescriptions,
  pageBackgroundLabels,
  type ButtonStyle,
  type PageBackgroundStyle
} from "@lib/page-style";
import {
  DEFAULT_PAGE_STYLE_OPTIONS,
  normalizePageStyleOptions,
  type PageStyleOptions
} from "@lib/page-style-options";
import { parseTrackPalette, type TrackPaletteVars } from "@lib/palette";

interface Props {
  backgroundStyle: PageBackgroundStyle;
  buttonStyle: ButtonStyle;
  pageStyleOptions?: PageStyleOptions | null;
  paletteJson?: string | null;
}

const { backgroundStyle, buttonStyle, pageStyleOptions = null, paletteJson = null } = Astro.props;
const options = normalizePageStyleOptions(pageStyleOptions ?? DEFAULT_PAGE_STYLE_OPTIONS);
const parsed = parseTrackPalette(paletteJson);
const cardPalette: TrackPaletteVars = {
  "--page-tint": parsed["--page-tint"] ?? STYLE_CARD_PREVIEW_PALETTE["--page-tint"]!,
  "--primary": parsed["--primary"] ?? STYLE_CARD_PREVIEW_PALETTE["--primary"]!,
  "--muted": parsed["--muted"] ?? STYLE_CARD_PREVIEW_PALETTE["--muted"]!,
  "--background": parsed["--background"] ?? "oklch(0.14 0.02 280)",
  "--surface": parsed["--surface"] ?? "oklch(0.18 0.02 280)"
};
const asciiCardPreview = asciiPatternDataUri(cardPalette, options.ascii.density, options.ascii.contrast);
const cardStyle = [
  `--card-tint: ${cardPalette["--page-tint"]}`,
  `--card-primary: ${cardPalette["--primary"]}`,
  `--card-muted: ${cardPalette["--muted"]}`,
  `--card-bg: ${cardPalette["--background"]}`,
  `--card-surface: ${cardPalette["--surface"]}`,
  `--ascii-card-preview: ${asciiCardPreview}`
].join("; ");
---

<section class="form-block" style={cardStyle} data-page-style-fields>
  <div class="block-head">
    <h2 class="section-title">Page appearance</h2>
    <p class="block-copy">Background and platform button styles fans see on the public link.</p>
  </div>
  <div class="block-body appearance-body">
    <fieldset class="style-fieldset">
      <legend>Background</legend>
      <div class="style-grid">
        {PAGE_BACKGROUND_STYLES.map((style) => (
          <label class:list={["style-card", "style-card--bg", `style-card--bg-${style}`, backgroundStyle === style && "is-selected"]}>
            <input
              type="radio"
              name="pageBackgroundStyle"
              value={style}
              checked={backgroundStyle === style}
              data-style-radio="background"
            />
            <span class="style-card__preview" aria-hidden="true"></span>
            <span class="style-card__copy">
              <span class="style-card__label">{pageBackgroundLabels[style]}</span>
              <span class="style-card__hint">{pageBackgroundDescriptions[style]}</span>
            </span>
          </label>
        ))}
      </div>
    </fieldset>

    <div class="style-knobs" data-style-knobs>
      <div class="style-knobs__panel" data-knob-panel="blur" hidden={backgroundStyle !== "blur"}>
        <p class="style-knobs__title">Blur controls</p>
        <label class="knob">
          <span>Intensity <output data-knob-output="blur.intensity">{options.blur.intensity.toFixed(2)}</output></span>
          <input type="range" name="style.blur.intensity" min="0.4" max="1.6" step="0.05" value={options.blur.intensity} data-knob="blur.intensity" />
        </label>
        <label class="knob">
          <span>Saturation <output data-knob-output="blur.saturate">{options.blur.saturate.toFixed(2)}</output></span>
          <input type="range" name="style.blur.saturate" min="0.5" max="1.8" step="0.05" value={options.blur.saturate} data-knob="blur.saturate" />
        </label>
      </div>

      <div class="style-knobs__panel" data-knob-panel="ascii" hidden={backgroundStyle !== "ascii"}>
        <p class="style-knobs__title">ASCII controls</p>
        <label class="knob">
          <span>Density</span>
          <select name="style.ascii.density" data-knob="ascii.density">
            <option value="sm" selected={options.ascii.density === "sm"}>Coarse</option>
            <option value="md" selected={options.ascii.density === "md"}>Balanced</option>
            <option value="lg" selected={options.ascii.density === "lg"}>Fine</option>
          </select>
        </label>
        <label class="knob">
          <span>Contrast <output data-knob-output="ascii.contrast">{options.ascii.contrast.toFixed(2)}</output></span>
          <input type="range" name="style.ascii.contrast" min="0.3" max="1.2" step="0.05" value={options.ascii.contrast} data-knob="ascii.contrast" />
        </label>
        <label class="knob">
          <span>Motion</span>
          <select name="style.ascii.motion" data-knob="ascii.motion">
            <option value="static" selected={options.ascii.motion === "static"}>Static</option>
            <option value="shimmer" selected={options.ascii.motion === "shimmer"}>Shimmer</option>
            <option value="live" selected={options.ascii.motion === "live"}>Live</option>
          </select>
        </label>
      </div>

      <div class="style-knobs__panel" data-knob-panel="mesh" hidden={backgroundStyle !== "mesh"}>
        <p class="style-knobs__title">Mesh controls</p>
        <label class="knob">
          <span>Speed <output data-knob-output="mesh.speed">{options.mesh.speed.toFixed(2)}</output></span>
          <input type="range" name="style.mesh.speed" min="0.35" max="2" step="0.05" value={options.mesh.speed} data-knob="mesh.speed" />
        </label>
        <label class="knob">
          <span>Intensity <output data-knob-output="mesh.intensity">{options.mesh.intensity.toFixed(2)}</output></span>
          <input type="range" name="style.mesh.intensity" min="0.35" max="1.6" step="0.05" value={options.mesh.intensity} data-knob="mesh.intensity" />
        </label>
      </div>

      <div class="style-knobs__panel" data-knob-panel="aurora" hidden={backgroundStyle !== "aurora"}>
        <p class="style-knobs__title">Aurora controls</p>
        <label class="knob">
          <span>Speed <output data-knob-output="aurora.speed">{options.aurora.speed.toFixed(2)}</output></span>
          <input type="range" name="style.aurora.speed" min="0.35" max="2" step="0.05" value={options.aurora.speed} data-knob="aurora.speed" />
        </label>
        <label class="knob">
          <span>Intensity <output data-knob-output="aurora.intensity">{options.aurora.intensity.toFixed(2)}</output></span>
          <input type="range" name="style.aurora.intensity" min="0.35" max="1.6" step="0.05" value={options.aurora.intensity} data-knob="aurora.intensity" />
        </label>
        <label class="knob">
          <span>Softness <output data-knob-output="aurora.blur">{options.aurora.blur.toFixed(2)}</output></span>
          <input type="range" name="style.aurora.blur" min="0.5" max="1.8" step="0.05" value={options.aurora.blur} data-knob="aurora.blur" />
        </label>
      </div>

      <div class="style-knobs__panel" data-knob-panel="vinyl" hidden={backgroundStyle !== "vinyl"}>
        <p class="style-knobs__title">Vinyl controls</p>
        <label class="knob">
          <span>Spin speed <output data-knob-output="vinyl.speed">{options.vinyl.speed.toFixed(2)}</output></span>
          <input type="range" name="style.vinyl.speed" min="0.35" max="2" step="0.05" value={options.vinyl.speed} data-knob="vinyl.speed" />
        </label>
        <label class="knob">
          <span>Groove contrast <output data-knob-output="vinyl.intensity">{options.vinyl.intensity.toFixed(2)}</output></span>
          <input type="range" name="style.vinyl.intensity" min="0.35" max="1.6" step="0.05" value={options.vinyl.intensity} data-knob="vinyl.intensity" />
        </label>
      </div>
    </div>

    <fieldset class="style-fieldset">
      <legend>Platform buttons</legend>
      <div class="style-grid style-grid--buttons">
        {BUTTON_STYLES.map((style) => (
          <label class:list={["style-card", "style-card--btn", `style-card--btn-${style}`, buttonStyle === style && "is-selected"]}>
            <input
              type="radio"
              name="buttonStyle"
              value={style}
              checked={buttonStyle === style}
            />
            <span class="style-card__preview style-card__preview--btn" aria-hidden="true">
              <span class="btn-swatch btn-swatch--spotify"></span>
              <span class="btn-swatch btn-swatch--apple"></span>
            </span>
            <span class="style-card__copy">
              <span class="style-card__label">{buttonStyleLabels[style]}</span>
              <span class="style-card__hint">{buttonStyleDescriptions[style]}</span>
            </span>
          </label>
        ))}
      </div>
    </fieldset>
  </div>
</section>

<script is:inline>
  (function initPageStyleKnobs() {
    const root = document.querySelector("[data-page-style-fields]");
    if (!root) return;

    function selectedBackground() {
      return root.querySelector("input[name='pageBackgroundStyle']:checked")?.value || "blur";
    }

    function syncPanels() {
      const style = selectedBackground();
      for (const panel of root.querySelectorAll("[data-knob-panel]")) {
        panel.hidden = panel.getAttribute("data-knob-panel") !== style;
      }
    }

    function syncOutputs(input) {
      const key = input.getAttribute("data-knob");
      if (!key) return;
      const output = root.querySelector(`[data-knob-output="${key}"]`);
      if (!output) return;
      const n = Number(input.value);
      output.textContent = Number.isFinite(n) ? n.toFixed(2) : input.value;
    }

    for (const input of root.querySelectorAll("input[data-style-radio='background']")) {
      input.addEventListener("change", syncPanels);
    }
    for (const input of root.querySelectorAll("[data-knob]")) {
      input.addEventListener("input", () => syncOutputs(input));
      syncOutputs(input);
    }
    syncPanels();

    window.collectPageStyleOptions = function collectPageStyleOptions() {
      const num = (name, fallback) => {
        const el = root.querySelector(`[data-knob="${name}"]`);
        const n = Number(el?.value);
        return Number.isFinite(n) ? n : fallback;
      };
      const str = (name, fallback) => root.querySelector(`[data-knob="${name}"]`)?.value || fallback;
      return {
        blur: {
          intensity: num("blur.intensity", 1),
          saturate: num("blur.saturate", 1)
        },
        ascii: {
          density: str("ascii.density", "md"),
          contrast: num("ascii.contrast", 0.7),
          motion: str("ascii.motion", "live")
        },
        mesh: {
          speed: num("mesh.speed", 1),
          intensity: num("mesh.intensity", 1)
        },
        aurora: {
          speed: num("aurora.speed", 1),
          intensity: num("aurora.intensity", 1),
          blur: num("aurora.blur", 1)
        },
        vinyl: {
          speed: num("vinyl.speed", 1),
          intensity: num("vinyl.intensity", 1)
        }
      };
    };
  })();
</script>

<style>
  .appearance-body {
    display: grid;
    gap: 1.35rem;
  }

  .style-fieldset {
    margin: 0;
    padding: 0;
    border: 0;
    min-width: 0;
  }

  .style-fieldset legend {
    margin-bottom: 0.55rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--foreground);
  }

  .style-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 11.5rem), 1fr));
    gap: 0.55rem;
  }

  .style-grid--buttons {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 10.5rem), 1fr));
  }

  .style-card {
    position: relative;
    display: grid;
    gap: 0.55rem;
    padding: 0.65rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--surface);
    cursor: pointer;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .style-card:hover {
    border-color: color-mix(in oklch, var(--accent) 35%, var(--border-strong));
  }

  .style-card.is-selected {
    border-color: var(--accent);
    background: color-mix(in oklch, var(--accent) 12%, var(--surface));
    box-shadow:
      0 0 0 2px var(--accent),
      0 0 0 4px var(--accent-soft);
  }

  .style-card input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .style-card__preview {
    display: block;
    height: 3.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .style-card__preview--btn {
    display: grid;
    gap: 0.3rem;
    padding: 0.45rem;
    background: oklch(0.14 0.01 265);
  }

  .btn-swatch {
    position: relative;
    display: block;
    height: 0.85rem;
    border-radius: 999px;
    background: oklch(0.28 0.006 265 / 0.8);
  }

  .style-card--bg-blur .style-card__preview {
    background:
      radial-gradient(circle at 30% 20%, color-mix(in oklch, var(--card-primary) 75%, transparent), transparent 58%),
      radial-gradient(circle at 72% 78%, color-mix(in oklch, var(--card-tint) 65%, transparent), transparent 55%),
      var(--card-bg);
    filter: blur(0.4px);
  }

  .style-card--bg-ascii .style-card__preview {
    background-image: var(--ascii-card-preview);
    background-size: cover;
    background-color: var(--card-bg);
    image-rendering: pixelated;
  }

  .style-card--bg-mesh .style-card__preview {
    position: relative;
    overflow: hidden;
    background: var(--card-bg);
  }

  .style-card--bg-mesh .style-card__preview::before,
  .style-card--bg-mesh .style-card__preview::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    filter: blur(10px);
    mix-blend-mode: hard-light;
    opacity: 0.9;
  }

  .style-card--bg-mesh .style-card__preview::before {
    width: 70%;
    height: 70%;
    top: -18%;
    left: -8%;
    background: radial-gradient(circle, color-mix(in oklch, var(--card-primary) 90%, transparent), transparent 58%);
  }

  .style-card--bg-mesh .style-card__preview::after {
    width: 65%;
    height: 65%;
    bottom: -22%;
    right: -12%;
    background: radial-gradient(circle, color-mix(in oklch, var(--card-tint) 85%, transparent), transparent 56%);
  }

  .style-card--bg-aurora .style-card__preview {
    position: relative;
    overflow: hidden;
    background: var(--card-bg);
  }

  .style-card--bg-aurora .style-card__preview::before,
  .style-card--bg-aurora .style-card__preview::after {
    content: "";
    position: absolute;
    width: 120%;
    height: 120%;
    top: -35%;
    left: -25%;
    border-radius: 50%;
    filter: blur(12px);
    mix-blend-mode: screen;
    opacity: 0.85;
  }

  .style-card--bg-aurora .style-card__preview::before {
    background: radial-gradient(ellipse 80% 50% at 40% 20%, color-mix(in oklch, var(--card-primary) 90%, transparent), transparent 62%);
  }

  .style-card--bg-aurora .style-card__preview::after {
    background: radial-gradient(ellipse 70% 45% at 68% 55%, color-mix(in oklch, var(--card-tint) 80%, transparent), transparent 60%);
    top: -20%;
    left: 10%;
  }

  .style-card--bg-vinyl .style-card__preview {
    position: relative;
    display: grid;
    place-items: center;
    background: var(--card-bg);
    overflow: hidden;
  }

  .style-card--bg-vinyl .style-card__preview::before {
    content: "";
    width: 78%;
    aspect-ratio: 1;
    border-radius: 50%;
    background:
      repeating-radial-gradient(
        circle at center,
        transparent 0 2px,
        color-mix(in oklch, var(--card-muted) 35%, transparent) 2px 3px
      ),
      radial-gradient(circle, color-mix(in oklch, var(--card-tint) 70%, var(--card-primary)), var(--card-bg) 72%);
    box-shadow: 0 0 0 1px oklch(1 0 0 / 0.06) inset;
  }

  .style-card--btn-logo-color .btn-swatch--spotify {
    background: linear-gradient(90deg, oklch(0.28 0.006 265 / 0.8), oklch(0.28 0.006 265 / 0.8));
    box-shadow: inset 2.2rem 0 0 #1ed760;
  }

  .style-card--btn-colored-border .btn-swatch--spotify {
    border: 1px solid #1ed760;
    background: oklch(0.24 0.006 265 / 0.75);
  }

  .style-card--btn-gradient-lr .btn-swatch--spotify {
    background: linear-gradient(90deg, oklch(0.28 0.006 265 / 0.85) 0%, color-mix(in srgb, #1ed760 35%, oklch(0.28 0.006 265)) 100%);
  }

  .style-card--btn-gradient-logo .btn-swatch--spotify {
    background: linear-gradient(90deg, oklch(0.28 0.006 265 / 0.85) 0%, color-mix(in srgb, #1ed760 42%, oklch(0.28 0.006 265)) 100%);
    box-shadow: inset 1.5rem 0 0 #1ed760;
  }

  .style-card--btn-full-color .btn-swatch--spotify {
    background: #1ed760;
    box-shadow: inset 0.55rem 0 0 -0.2rem oklch(0.15 0.006 265);
  }

  .style-card--btn-full-color .btn-swatch--spotify::before,
  .style-card--btn-full-color .btn-swatch--apple::before {
    content: "";
    position: absolute;
    left: 0.28rem;
    top: 50%;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 50%;
    transform: translateY(-50%);
    background: oklch(0.15 0.006 265);
  }

  .style-card--btn-full-color .btn-swatch--apple {
    background: #fa5a6e;
    box-shadow: inset 0.55rem 0 0 -0.2rem oklch(0.98 0.004 265);
  }

  .style-card--btn-full-color .btn-swatch--apple::before {
    background: oklch(0.98 0.004 265);
  }

  .style-card__copy {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .style-card__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--foreground);
  }

  .style-card__hint {
    font-size: var(--text-xs);
    line-height: 1.35;
    color: var(--muted);
  }

  .style-knobs {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: color-mix(in oklch, var(--surface) 88%, var(--background));
    padding: 0.85rem 0.95rem;
  }

  .style-knobs__panel[hidden] {
    display: none;
  }

  .style-knobs__title {
    margin: 0 0 0.65rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--foreground);
  }

  .knob {
    display: grid;
    gap: 0.3rem;
    margin-bottom: 0.65rem;
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .knob:last-child {
    margin-bottom: 0;
  }

  .knob span {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--foreground);
    font-weight: 500;
  }

  .knob output {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .knob input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
  }

  .knob select {
    width: 100%;
    min-height: 2.25rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--foreground);
    padding: 0.35rem 0.55rem;
  }
</style>
