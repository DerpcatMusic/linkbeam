---
interface Props {
  title: string;
  subtitle?: string;
  defaultOpen?: boolean;
  id: string;
}

const { title, subtitle, defaultOpen = true, id } = Astro.props;
---

<details class="collapsible-section" id={id} open={defaultOpen}>
  <summary class="collapsible-summary">
    <span class="collapsible-heading">
      <span class="section-title">{title}</span>
      {subtitle && <span class="muted collapsible-subtitle">{subtitle}</span>}
    </span>
    <span class="collapsible-chevron" aria-hidden="true"></span>
  </summary>
  <div class="collapsible-body">
    <slot />
  </div>
</details>

<style>
  .collapsible-section {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.65rem;
    padding-top: 0.35rem;
  }

  .collapsible-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    cursor: pointer;
    list-style: none;
    padding: 0.2rem 0;
  }

  .collapsible-summary::-webkit-details-marker {
    display: none;
  }

  .collapsible-heading {
    display: grid;
    gap: 0.15rem;
  }

  .collapsible-subtitle {
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  .collapsible-chevron {
    width: 0.45rem;
    height: 0.45rem;
    border-right: 2px solid var(--muted);
    border-bottom: 2px solid var(--muted);
    transform: rotate(45deg);
    transition: transform 150ms ease;
    flex-shrink: 0;
  }

  .collapsible-section[open] .collapsible-chevron {
    transform: rotate(-135deg);
    margin-top: 0.2rem;
  }

  .collapsible-summary:hover .collapsible-chevron,
  .collapsible-summary:focus-visible .collapsible-chevron {
    border-color: var(--foreground);
  }

  .collapsible-summary:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-offset);
    border-radius: var(--radius-sm);
  }

  .collapsible-body {
    display: grid;
    gap: 0.85rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .collapsible-chevron {
      transition: none;
    }
  }
</style>
