---
import type { CampaignPerformanceRow } from "@lib/meta-ads-insights";
import { formatAdMoney } from "@lib/meta-ads-insights";

interface Props {
  rows: CampaignPerformanceRow[];
  currency: string;
  empty?: string;
  error?: string | null;
  fetchedAt?: string;
}

const { rows, currency, empty = "No campaign data for this link in range.", error, fetchedAt } = Astro.props;
---

{error ? (
  <p class="muted empty-line">{error}</p>
) : rows.length === 0 ? (
  <p class="muted empty-line">{empty}</p>
) : (
  <>
  <div class="admin-table-wrap">
    <table class="admin-table meta-campaign-table">
      <thead>
        <tr>
          <th>Campaign</th>
          <th>Your taps</th>
          <th>Spend</th>
          <th>Impr.</th>
          <th>Meta clicks</th>
          <th>Meta results</th>
          <th>Cost / tap</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td>
              <div class="campaign-name-cell">
                <span data-sensitive>{row.displayName}</span>
                {row.campaignId && row.displayName !== row.campaignId && (
                  <span class="muted campaign-id" data-sensitive>{row.campaignId}</span>
                )}
              </div>
            </td>
            <td class="tabular-nums">{row.yourTaps}</td>
            <td class="tabular-nums">{formatAdMoney(row.spend, currency)}</td>
            <td class="tabular-nums">{row.impressions ?? "—"}</td>
            <td class="tabular-nums">{row.metaClicks ?? "—"}</td>
            <td class="tabular-nums">{row.metaResults ?? "—"}</td>
            <td class="tabular-nums">{formatAdMoney(row.costPerYourTap, currency)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {fetchedAt && (
    <p class="muted meta-footnote">Meta Ads data cached · {fetchedAt.slice(0, 19).replace("T", " ")} UTC</p>
  )}
  </>
)}

<style>
  .meta-campaign-table th:not(:first-child),
  .meta-campaign-table td:not(:first-child) {
    text-align: right;
    white-space: nowrap;
  }

  .campaign-name-cell {
    display: grid;
    gap: 0.1rem;
    min-width: 0;
  }

  .campaign-name-cell > span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 18rem;
  }

  .campaign-id {
    font-size: var(--text-xs);
    font-family: var(--mono);
  }

  .meta-footnote {
    margin: 0.45rem 0 0;
    font-size: var(--text-xs);
  }

  .empty-line {
    margin: 0;
    padding: 0.6rem 0;
    font-size: var(--text-sm);
  }
</style>
